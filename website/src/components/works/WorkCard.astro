---
/**
 * WorkCard.astro — 作品縮圖卡（首頁精選 + 作品列表共用）
 * 白底設計：圖 + 下方標題區（不再文字壓在圖上）
 */
import SmartImage from "../ui/SmartImage.astro";
import type { IPublicProject } from "../../types/project";
import { resolveThumbnail } from "../../lib/youtube";

interface Props {
    work: IPublicProject;
    priority?: boolean;
}
const { work, priority = false } = Astro.props;
const thumb = resolveThumbnail(work.youtube_id, work.slug, "hq");
---

<a href={`/works/${work.slug}`} class="group block">
    <div class="relative overflow-hidden aspect-video bg-neutral-100 mb-4">
        <SmartImage src={thumb}
                    alt={work.title}
                    width={1280} height={720}
                    widths={[400, 800, 1280]}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                    loading={priority ? "eager" : "lazy"}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
        {work.featured && (
            <div class="absolute top-3 left-3 text-[10px] tracking-[0.25em] uppercase px-2 py-1 bg-white/95 text-[#c9372c] border border-[#c9372c]/30">
                Featured
            </div>
        )}
    </div>

    <div>
        {(work.categories.length > 0 || work.client) && (
            <div class="flex items-center gap-2 mb-2 text-[10px] text-[#c9372c] flex-wrap">
                {work.categories.slice(0, 2).map((cat, i) => (
                    <>{i > 0 && <span class="text-[#c9372c]/40">·</span>}<span class="tracking-[0.3em] uppercase">{cat}</span></>
                ))}
                {work.client && (
                    <>
                        {work.categories.length > 0 && <span class="text-[#c9372c]/40">·</span>}
                        <span class="tracking-wider">{work.client}</span>
                    </>
                )}
            </div>
        )}
        <h3 class="text-base sm:text-lg font-medium text-neutral-900 tracking-wide leading-snug group-hover:text-[#c9372c] transition-colors">
            {work.title}
        </h3>
        {work.tags && work.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-2">
                {work.tags.slice(0, 3).map(t => (
                    <span class="text-[10px] tracking-wider text-neutral-500 bg-neutral-100 px-2 py-0.5 rounded-sm">
                        #{t.replace(/^tag-/, "")}
                    </span>
                ))}
            </div>
        )}
    </div>
</a>

---
/**
 * WorkCard.astro — 作品縮圖卡（首頁精選 + 作品列表共用）
 */
import type { IPublicProject } from "../../types/project";
import { youtubeThumbnail } from "../../lib/youtube";

interface Props {
    work: IPublicProject;
    priority?: boolean;  // 首屏圖片可設 true
}

const { work, priority = false } = Astro.props;
const thumb = work.thumbnail_url || youtubeThumbnail(work.youtube_id, "hq");
---

<a href={`/works/${work.slug}`}
   class="group block relative overflow-hidden bg-neutral-950 aspect-video">

    {thumb && (
        <img src={thumb}
             alt={work.title}
             loading={priority ? "eager" : "lazy"}
             class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
             onerror="this.style.display='none'" />
    )}

    {!thumb && (
        <div class="absolute inset-0 bg-gradient-to-br from-neutral-900 to-neutral-800 flex items-center justify-center">
            <span class="text-neutral-600 text-xs tracking-widest uppercase">No Preview</span>
        </div>
    )}

    <!-- Hover 遮罩 -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent opacity-60 group-hover:opacity-100 transition-opacity"></div>

    <div class="absolute inset-x-0 bottom-0 p-4 sm:p-5">
        <div class="flex items-center gap-2 mb-2">
            {work.year && (
                <span class="text-xs text-neutral-400 tracking-widest">{work.year}</span>
            )}
            {work.categories.slice(0, 2).map(cat => (
                <span class="text-[10px] uppercase tracking-[0.2em] text-neutral-500">· {cat}</span>
            ))}
        </div>
        <h3 class="text-base sm:text-lg font-light text-white tracking-wide leading-snug">
            {work.title}
        </h3>
        {work.client && (
            <p class="text-xs text-neutral-400 mt-1 tracking-wide">{work.client}</p>
        )}
    </div>

    {work.featured && (
        <div class="absolute top-3 right-3 text-[10px] tracking-[0.2em] uppercase px-2 py-1 bg-black/60 border border-white/20 text-white/90">
            Featured
        </div>
    )}
</a>

---
/**
 * Header.astro — 頂部導覽列（對齊原站設計：Logo 左 / NAV 中 / 社群右）
 * Hero 區全螢幕時 header 透明疊在上方，往下滾加深 blur
 */
import type { IWebsiteMeta } from "../../types/meta";
import LanguageToggle from "./LanguageToggle.astro";
import Tr from "../ui/Tr.astro";

interface Props { meta: IWebsiteMeta }
const { meta } = Astro.props;

const navItems = [
    { href: "/",         k: "nav_home" as const },
    { href: "/works",    k: "nav_works" as const },
    { href: "/services", k: "nav_services" as const },
    { href: "/about",    k: "nav_about" as const },
    { href: "/contact",  k: "nav_contact" as const },
];

const currentPath = Astro.url.pathname;
const socials = [
    { url: meta.social.youtube,   name: "YouTube",   svg: "M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5a3 3 0 00-2.1 2.1C0 8 0 12 0 12s0 4 .5 5.8a3 3 0 002.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 002.1-2.1c.5-1.8.5-5.8.5-5.8s0-4-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z" },
    { url: meta.social.instagram, name: "Instagram", svg: "M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.9.9 1.4.2.4.4 1.1.4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.9.7-1.4.9-.4.2-1.1.4-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.3-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.9-.9-1.4-.2-.4-.4-1.1-.4-2.2-.1-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.9-.7 1.4-.9.4-.2 1.1-.4 2.2-.4 1.2-.1 1.6-.1 4.8-.1M12 0C8.7 0 8.3 0 7.1.1S5 .3 4.1.7c-.9.4-1.7.8-2.5 1.6S.4 3.9.1 4.8C-.2 5.7-.3 6.7-.4 7.9-.5 9.1-.5 9.5-.5 12.8s0 3.7.1 4.9.3 2 .7 2.9c.4.9.8 1.7 1.6 2.5s1.6 1.2 2.5 1.6c.9.3 1.9.6 3.1.7 1.2.1 1.6.1 4.9.1s3.7 0 4.9-.1c1.2-.1 2-.3 2.9-.7.9-.4 1.7-.8 2.5-1.6s1.2-1.6 1.6-2.5c.3-.9.6-1.9.7-3.1.1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.2-.3-2-.7-2.9-.4-.9-.8-1.7-1.6-2.5S20.1.4 19.2.1c-.9-.3-1.9-.6-3.1-.7C14.9 0 14.5 0 11.2 0H12zm0 5.8a6.2 6.2 0 106.2 6.2A6.2 6.2 0 0012 5.8zm0 10.2a4 4 0 114-4 4 4 0 01-4 4zm7.8-10.4a1.4 1.4 0 11-1.4-1.4 1.4 1.4 0 011.4 1.4z" },
    { url: meta.social.facebook,  name: "Facebook",  svg: "M24 12a12 12 0 10-13.9 11.9v-8.4h-3V12h3V9.4c0-3 1.8-4.6 4.5-4.6 1.3 0 2.7.2 2.7.2v2.9h-1.5c-1.5 0-2 .9-2 1.9V12h3.3l-.5 3.5h-2.8v8.4A12 12 0 0024 12z" },
].filter(s => !!s.url);
---

<header id="site-header"
        class="fixed top-0 inset-x-0 z-50 bg-white/95 backdrop-blur-md border-b border-neutral-200/60 transition-shadow"
        data-at-top="1">
    <div class="max-w-[1600px] mx-auto px-4 sm:px-8 h-16 sm:h-20 flex items-center justify-between gap-4">

        <!-- 左：Logo -->
        <a href="/" class="flex-shrink-0 flex items-center gap-3" aria-label="Home">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                <circle cx="18" cy="15" r="8" fill="#c9372c" />
                <line x1="6" y1="24" x2="30" y2="24" stroke="#c9372c" stroke-width="1.5" />
                <line x1="8" y1="27" x2="28" y2="27" stroke="#c9372c" stroke-width="1.5" opacity="0.7" />
                <line x1="10" y1="30" x2="26" y2="30" stroke="#c9372c" stroke-width="1.5" opacity="0.4" />
            </svg>
            <span class="hidden sm:inline text-sm tracking-[0.25em] font-light text-neutral-800">
                <span data-lang-zh>{meta.company_name_zh}</span>
                <span data-lang-en>{meta.company_name_en}</span>
            </span>
        </a>

        <!-- 中：主導覽（桌機） -->
        <nav class="hidden md:flex items-center gap-10 text-xs tracking-[0.35em] uppercase">
            {navItems.map(item => (
                <a href={item.href}
                   class:list={[
                       "transition-colors hover:text-[#c9372c]",
                       currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
                           ? "text-neutral-900 font-medium" : "text-neutral-600",
                   ]}>
                    <Tr k={item.k} />
                </a>
            ))}
        </nav>

        <!-- 右：社群 icons + 語言 + 手機漢堡 -->
        <div class="flex items-center gap-4">
            <div class="hidden md:flex items-center gap-3">
                {socials.map(s => (
                    <a href={s.url} target="_blank" rel="noopener" aria-label={s.name}
                       class="text-neutral-500 hover:text-[#c9372c] transition-colors">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d={s.svg} /></svg>
                    </a>
                ))}
            </div>
            <LanguageToggle />
            <button type="button" aria-label="menu"
                    class="md:hidden text-neutral-700"
                    data-mobile-nav-toggle>
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" d="M3 6h18M3 12h18M3 18h18" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile nav -->
    <nav class="hidden flex-col gap-4 px-6 py-5 bg-white border-t border-neutral-200" data-mobile-nav>
        {navItems.map(item => (
            <a href={item.href} class="text-neutral-700 hover:text-[#c9372c] text-sm tracking-[0.2em] uppercase">
                <Tr k={item.k} />
            </a>
        ))}
        <div class="flex items-center gap-4 pt-3 border-t border-neutral-200">
            {socials.map(s => (
                <a href={s.url} target="_blank" rel="noopener" aria-label={s.name}
                   class="text-neutral-500 hover:text-[#c9372c]">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d={s.svg} /></svg>
                </a>
            ))}
        </div>
    </nav>
</header>

<style>
    #site-header[data-at-top="0"] {
        box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    }
</style>

<script>
    // 滾動偵測：頂部 transparent / 下滑加 blur
    const header = document.getElementById("site-header");
    function updateHeader() {
        if (!header) return;
        const atTop = window.scrollY < 20;
        header.setAttribute("data-at-top", atTop ? "1" : "0");
    }
    window.addEventListener("scroll", updateHeader, { passive: true });
    updateHeader();

    // Mobile toggle
    const toggle = document.querySelector("[data-mobile-nav-toggle]");
    const nav = document.querySelector("[data-mobile-nav]");
    toggle?.addEventListener("click", () => {
        nav?.classList.toggle("hidden");
        nav?.classList.toggle("flex");
    });
</script>

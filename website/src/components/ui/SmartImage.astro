---
/**
 * SmartImage.astro — Astro `<Image>` wrapper，遇到 sharp 無法處理的 URL
 * 自動降級成原生 `<img>`，仍保留 width/height 防 CLS。
 *
 * 「可優化」判定：
 * 1. 本地路徑（/foo, ./foo, ../foo）→ 直接走 sharp
 * 2. 遠端 URL 屬於 ALLOWED_REMOTE_HOSTS（必須跟 astro.config.mjs `image.domains` 同步）
 *    → 走 sharp
 * 3. 其他遠端（picsum.photos / Gravatar / 任意 CDN）→ 降級回 `<img>`
 *    避免 build fail（sharp 拒收 redirect / 未授權 host）
 *
 * 介面收斂到實際會用的 prop：src / alt / width / height（必填）+
 * widths / sizes（給 srcset，sharp-only）+ loading / class。
 */
import { Image } from "astro:assets";

interface Props {
    src: string;
    alt: string;
    width: number;
    height: number;
    widths?: number[];
    sizes?: string;
    loading?: "eager" | "lazy";
    fetchpriority?: "high" | "low" | "auto";   // LCP 圖設 high 讓瀏覽器優先下載
    class?: string;
}

const { src, alt, width, height, widths, sizes, loading, fetchpriority, class: className } = Astro.props;

// 必須跟 astro.config.mjs `image.domains` 同步。新增遠端來源時兩邊都要加。
const ALLOWED_REMOTE_HOSTS = new Set([
    "img.youtube.com",
    "i.ytimg.com",
]);

const hostMatch = src.match(/^https?:\/\/([^/]+)/);
const isRemote = !!hostMatch;
const isAllowedRemote = isRemote && ALLOWED_REMOTE_HOSTS.has(hostMatch[1]);
const optimizable = !isRemote || isAllowedRemote;
---

{optimizable ? (
    <Image src={src} alt={alt}
           width={width} height={height}
           widths={widths} sizes={sizes}
           loading={loading} fetchpriority={fetchpriority} class={className} />
) : (
    <img src={src} alt={alt}
         width={width} height={height}
         loading={loading} fetchpriority={fetchpriority} class={className} />
)}

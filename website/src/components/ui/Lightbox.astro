---
/**
 * Lightbox.astro — 通用全螢幕燈箱（單例，每頁放一個）
 *
 * 掃描頁面上所有 [data-osun-lightbox] 相簿容器，點其中的 .osun-cell 即開啟。
 * 每個 .osun-cell 需帶：data-full（原圖 URL）、data-caption（可空）。
 * cell 在 DOM 的順序＝相簿順序，燈箱左右切換走完整組。
 * 純 vanilla、無外部庫（CSP 禁 CDN）。鍵盤 ←/→/Esc、點背景關閉、focus 還原。
 */
---

<div class="osun-lb" role="dialog" aria-modal="true" aria-label="放大檢視">
    <button class="osun-lb-close" type="button" aria-label="關閉">✕</button>
    <button class="osun-lb-nav osun-lb-prev" type="button" aria-label="上一張">‹</button>
    <figure class="osun-lb-stage">
        <img class="osun-lb-img" alt="" />
        <figcaption class="osun-lb-meta">
            <span class="osun-lb-count"></span>
            <span class="osun-lb-cap"></span>
        </figcaption>
    </figure>
    <button class="osun-lb-nav osun-lb-next" type="button" aria-label="下一張">›</button>
</div>

<style is:global>
    .osun-lb{
        position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;
        padding:clamp(16px,4vw,56px);background:rgba(18,17,16,.94);
        -webkit-backdrop-filter:blur(3px);backdrop-filter:blur(3px);
        opacity:0;visibility:hidden;transition:opacity .22s ease,visibility .22s;
    }
    .osun-lb.open{opacity:1;visibility:visible}
    .osun-lb-stage{margin:0;display:flex;flex-direction:column;align-items:center;gap:14px;max-width:100%}
    .osun-lb-img{
        max-width:min(1200px,92vw);max-height:78vh;width:auto;height:auto;object-fit:contain;
        border-radius:3px;box-shadow:0 30px 80px rgba(0,0,0,.5);background:#0d0d0d;
    }
    .osun-lb.open .osun-lb-img{animation:osun-pop .3s cubic-bezier(.2,.8,.2,1)}
    @keyframes osun-pop{from{opacity:0;transform:scale(.985)}to{opacity:1;transform:none}}
    .osun-lb-meta{display:flex;gap:14px;align-items:center;color:#eceae7;justify-content:center;flex-wrap:wrap}
    .osun-lb-count{font-size:12px;letter-spacing:.16em;color:#b7b2ad;font-variant-numeric:tabular-nums}
    .osun-lb-cap{font-size:14px;letter-spacing:.02em}
    .osun-lb-nav{
        position:absolute;top:50%;transform:translateY(-50%);width:48px;height:48px;border-radius:50%;
        border:1px solid rgba(255,255,255,.25);background:rgba(0,0,0,.32);color:#fff;font-size:22px;
        cursor:pointer;display:grid;place-items:center;transition:background .2s,border-color .2s;
    }
    .osun-lb-nav:hover{background:#c9372c;border-color:#c9372c}
    .osun-lb-nav:focus-visible{outline:2px solid #fff;outline-offset:2px}
    .osun-lb-nav[hidden]{display:none}
    .osun-lb-prev{left:16px}
    .osun-lb-next{right:16px}
    @media(min-width:1000px){.osun-lb-prev{left:36px}.osun-lb-next{right:36px}}
    .osun-lb-close{
        position:absolute;top:16px;right:16px;width:42px;height:42px;border-radius:50%;
        border:1px solid rgba(255,255,255,.25);background:rgba(0,0,0,.35);color:#fff;font-size:18px;cursor:pointer;
    }
    .osun-lb-close:hover{background:#c9372c;border-color:#c9372c}
    .osun-lb-close:focus-visible{outline:2px solid #fff;outline-offset:2px}
    @media(prefers-reduced-motion:reduce){
        .osun-lb,.osun-lb-img{transition:none;animation:none}
    }
</style>

<script>
    (() => {
        const lb = document.querySelector<HTMLElement>(".osun-lb");
        if (!lb) return;
        const imgEl = lb.querySelector<HTMLImageElement>(".osun-lb-img")!;
        const capEl = lb.querySelector<HTMLElement>(".osun-lb-cap")!;
        const countEl = lb.querySelector<HTMLElement>(".osun-lb-count")!;
        const prevB = lb.querySelector<HTMLButtonElement>(".osun-lb-prev")!;
        const nextB = lb.querySelector<HTMLButtonElement>(".osun-lb-next")!;
        const closeB = lb.querySelector<HTMLButtonElement>(".osun-lb-close")!;

        let list: { url: string; cap: string }[] = [];
        let idx = 0;
        let lastFocus: HTMLElement | null = null;

        function show() {
            const it = list[idx];
            if (!it) return;
            imgEl.src = it.url;
            imgEl.alt = it.cap || "";
            capEl.textContent = it.cap || "";
            countEl.textContent = list.length > 1 ? `${idx + 1} / ${list.length}` : "";
            const single = list.length < 2;
            prevB.hidden = single;
            nextB.hidden = single;
            // 預載鄰圖
            if (!single) {
                [idx + 1, idx - 1].forEach(k => {
                    const it2 = list[(k + list.length) % list.length];
                    if (it2) { const im = new Image(); im.src = it2.url; }
                });
            }
        }
        function open(cells: HTMLElement[], i: number) {
            list = cells.map(c => ({ url: c.dataset.full || "", cap: c.dataset.caption || "" }));
            idx = i;
            lastFocus = document.activeElement as HTMLElement;
            lb.classList.add("open");
            document.body.style.overflow = "hidden";
            show();
            closeB.focus();
        }
        function close() {
            lb.classList.remove("open");
            document.body.style.overflow = "";
            if (lastFocus && lastFocus.focus) lastFocus.focus();
        }
        function move(d: number) {
            const n = list.length;
            if (!n) return;
            idx = (idx + d + n) % n;
            show();
        }

        document.querySelectorAll<HTMLElement>("[data-osun-lightbox]").forEach(gal => {
            gal.addEventListener("click", e => {
                const cell = (e.target as HTMLElement).closest<HTMLElement>(".osun-cell");
                if (!cell || !gal.contains(cell)) return;
                const cells = Array.from(gal.querySelectorAll<HTMLElement>(".osun-cell"));
                open(cells, cells.indexOf(cell));
            });
        });
        closeB.addEventListener("click", close);
        prevB.addEventListener("click", () => move(-1));
        nextB.addEventListener("click", () => move(1));
        lb.addEventListener("click", e => { if (e.target === lb) close(); });
        document.addEventListener("keydown", e => {
            if (!lb.classList.contains("open")) return;
            if (e.key === "Escape") close();
            else if (e.key === "ArrowRight") move(1);
            else if (e.key === "ArrowLeft") move(-1);
        });
    })();
</script>

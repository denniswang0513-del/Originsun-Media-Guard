---
/**
 * Testimonials.astro — 客戶證言段（信任堆疊最重要的一環）
 *
 * 版面：上方顯著的整體評分（4.9/5 + 25 則評價），下方 3 欄證言卡。
 * 不用 JS 輪播（避免 JS cost）；4 則顯示前 3 則，桌機 3-col、手機直排。
 */
import Tr from "../ui/Tr.astro";
import type { ITestimonial } from "../../types/seo";

interface Props {
    /** DB 客戶證言（admin「SEO 內容」可編）；空陣列則整段不渲染。 */
    testimonials?: ITestimonial[];
    /** 整體評分顯示值（admin「🏠 首頁設定」可編，預設 4.9） */
    ratingValue?: string;
    /** 整體評分則數（admin「🏠 首頁設定」可編，預設 25） */
    ratingCount?: string;
    /** admin 可編輯的首頁文案（copy.home.*）；空欄位則用硬寫 fallback。 */
    copy?: Record<string, string>;
}
const {
    testimonials = [],
    ratingValue = "4.9",
    ratingCount = "25",
    copy = {},
} = Astro.props;

const shown = testimonials
    .filter(t => t.visible)
    .sort((a, b) => a.sort_order - b.sort_order)
    .slice(0, 3);

/** 取作者名首字當頭像（DB testimonial 無 avatar 欄位） */
function initial(name: string): string {
    return (name || "").trim().charAt(0) || "·";
}
---

{shown.length > 0 && (
<section class="bg-neutral-100 py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- 章節 header：左邊標題、右邊整體評分 -->
        <div class="flex items-end justify-between mb-14 flex-wrap gap-6">
            <div>
                <p class="text-xs tracking-[0.4em] text-[#c9372c] uppercase mb-3">{copy.testimonials_eyebrow ?? "Testimonials"}</p>
                <h2 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 leading-tight max-w-xl">
                    <Tr zh={copy.testimonials_title_zh ?? "客戶的真實回饋"} en={copy.testimonials_title_en ?? "What Clients Say"} />
                </h2>
            </div>

            <!-- 整體評分 badge -->
            <div class="flex items-center gap-4 bg-white px-6 py-4 border border-neutral-200">
                <div class="text-4xl font-bold tracking-tight text-neutral-900">{ratingValue}</div>
                <div>
                    <div class="text-[#c9372c] text-sm tracking-widest">★★★★★</div>
                    <div class="text-xs text-neutral-500 tracking-wide mt-1">
                        <Tr zh={`基於 ${ratingCount} 則真實評價`} en={`From ${ratingCount} client reviews`} />
                    </div>
                </div>
            </div>
        </div>

        <!-- 3 欄證言 -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {shown.map(t => (
                <article class="bg-white p-8 sm:p-10 flex flex-col">
                    <!-- 星星 -->
                    <div class="text-[#c9372c] text-sm tracking-widest mb-5">
                        {"★".repeat(t.rating)}
                    </div>

                    <!-- 引言 -->
                    <blockquote class="text-[15px] sm:text-base text-neutral-700 leading-[1.85] tracking-wide flex-1 mb-8">
                        <span data-lang-zh>「{t.content_zh}」</span>
                        <span data-lang-en>"{t.content_en || t.content_zh}"</span>
                    </blockquote>

                    <!-- 作者資訊 -->
                    <div class="flex items-center gap-3 border-t border-neutral-200 pt-5">
                        <div class="w-11 h-11 rounded-full overflow-hidden bg-neutral-200 flex-shrink-0 flex items-center justify-center text-sm font-bold text-neutral-500">
                            {initial(t.author_zh)}
                        </div>
                        <div class="min-w-0">
                            <div class="text-sm font-bold text-neutral-900 tracking-wide truncate">
                                <Tr zh={t.author_zh} en={t.author_en || t.author_zh} />
                            </div>
                            <div class="text-xs text-neutral-500 tracking-wide truncate">
                                <Tr zh={t.role_zh || ""} en={t.role_en || t.role_zh || ""} />{t.company ? ` · ${t.company}` : ""}
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>
)}

---
/**
 * FeaturedWorks.astro — 首頁精選作品 6 宮格
 */
import type { IPublicProject } from "../../types/project";
import WorkCard from "../works/WorkCard.astro";
import { STR } from "../../lib/i18n";

interface Props { works: IPublicProject[] }
const { works } = Astro.props;
---

<section id="featured" class="bg-black py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-12">
            <div>
                <p class="text-xs tracking-[0.4em] text-neutral-500 uppercase mb-2">
                    <span data-lang-zh>精選</span>
                    <span data-lang-en>Selected</span>
                </p>
                <h2 class="text-3xl sm:text-4xl font-light tracking-tight">
                    <span data-lang-zh>{STR.featured_title.zh}</span>
                    <span data-lang-en>{STR.featured_title.en}</span>
                </h2>
            </div>
            <a href="/works"
               class="hidden sm:inline-block text-sm tracking-widest text-neutral-400 hover:text-white transition-colors">
                <span data-lang-zh>{STR.featured_viewall.zh}</span>
                <span data-lang-en>{STR.featured_viewall.en}</span>
            </a>
        </div>

        {works.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
                {works.map((w, i) => <WorkCard work={w} priority={i < 3} />)}
            </div>
        ) : (
            <div class="py-20 text-center text-neutral-500">
                <span data-lang-zh>目前沒有精選作品。到官網管理 Tab 把作品設為精選。</span>
                <span data-lang-en>No featured works yet.</span>
            </div>
        )}

        <div class="sm:hidden text-center mt-10">
            <a href="/works"
               class="inline-block text-sm tracking-widest text-neutral-400 hover:text-white">
                <span data-lang-zh>{STR.featured_viewall.zh}</span>
                <span data-lang-en>{STR.featured_viewall.en}</span>
            </a>
        </div>
    </div>
</section>

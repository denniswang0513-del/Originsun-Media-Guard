---
/**
 * FeaturedWorks.astro — 首頁精選作品（白底）
 */
import type { IPublicProject } from "../../types/project";
import WorkCard from "../works/WorkCard.astro";
import Tr from "../ui/Tr.astro";

interface Props { works: IPublicProject[] }
const { works } = Astro.props;
---

<section id="featured" class="bg-white py-24 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-12">
            <div>
                <p class="text-xs tracking-[0.4em] text-neutral-500 uppercase mb-2">
                    <Tr zh="精選" en="Selected" />
                </p>
                <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-neutral-900">
                    <Tr k="featured_title" />
                </h2>
            </div>
            <a href="/works"
               class="hidden sm:inline-block text-sm tracking-[0.2em] uppercase text-neutral-500 hover:text-[#c9372c] transition-colors">
                <Tr k="featured_viewall" />
            </a>
        </div>

        {works.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
                {works.map((w, i) => <WorkCard work={w} priority={i < 3} />)}
            </div>
        ) : (
            <div class="py-20 text-center text-neutral-500">
                <Tr zh="目前沒有精選作品" en="No featured works yet" />
            </div>
        )}

        <div class="sm:hidden text-center mt-10">
            <a href="/works"
               class="inline-block text-sm tracking-[0.2em] uppercase text-neutral-500 hover:text-[#c9372c]">
                <Tr k="featured_viewall" />
            </a>
        </div>
    </div>
</section>

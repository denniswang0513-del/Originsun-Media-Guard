---
/**
 * FeaturedWorks.astro — 首頁精選作品（全寬橫幅 2 列橫向捲動）
 *
 * 版面：
 *   [章節標題                         ← / →] ← 箭頭在右上角
 *   ┌──┬──┬──┬──┬──…
 *   │  │  │  │  │      每格 aspect-video，2 列橫向流動
 *   └──┴──┴──┴──┴──…
 *   （容器 edge-to-edge 滿版、scroll-snap、左右箭頭用 scrollBy）
 *
 * 箭頭只需要 ~15 行 inline JS；若無 JS 使用者仍可用觸控 / 滾輪橫向捲。
 */
import SmartImage from "../ui/SmartImage.astro";
import type { IPublicProject } from "../../types/project";
import { resolveThumbnailAsync } from "../../lib/youtube";
import Tr from "../ui/Tr.astro";
import { STR } from "../../lib/i18n";

interface Props {
    works: IPublicProject[];
    /** admin 可編輯的首頁文案（copy.home.*）；空欄位則用硬寫 fallback。 */
    copy?: Record<string, string>;
}
const { works, copy = {} } = Astro.props;

// build-time HEAD check 過濾沒 maxres 的舊片(YouTube 對非 HD 上傳不發 maxresdefault),
// 自動降到 hq 避免 sharp 抓 404 中斷 build。
const thumbs = await Promise.all(
    works.map(w => resolveThumbnailAsync(w.youtube_id, w.slug, "maxres")),
);
---

<section id="featured" class="bg-white py-24 sm:py-32">

    <!-- 章節標題（內縮） -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12 sm:mb-16">
        <div class="flex items-end justify-between gap-6 flex-wrap">
            <div>
                <p class="text-xs tracking-[0.4em] text-[#c9372c] uppercase mb-3">{copy.featured_eyebrow ?? "Selected"}</p>
                <h2 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 leading-tight">
                    <Tr zh={copy.featured_title_zh ?? STR.featured_title.zh} en={copy.featured_title_en ?? STR.featured_title.en} />
                </h2>
            </div>

            <!-- 右側：查看全部 + 左右箭頭 -->
            <div class="flex items-center gap-6">
                <a href="/works"
                   class="hidden sm:inline-flex items-center gap-3 text-xs tracking-[0.3em] uppercase text-neutral-500 hover:text-[#c9372c] transition-colors">
                    <Tr zh="全部作品" en="All works" />
                    <span>→</span>
                </a>
                <div class="flex gap-2">
                    <button type="button" data-scroll="prev" aria-label="Previous"
                            class="w-11 h-11 flex items-center justify-center border border-neutral-300 text-neutral-700 hover:bg-neutral-900 hover:text-white hover:border-neutral-900 transition-colors">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M15 18l-6-6 6-6" />
                        </svg>
                    </button>
                    <button type="button" data-scroll="next" aria-label="Next"
                            class="w-11 h-11 flex items-center justify-center border border-neutral-300 text-neutral-700 hover:bg-neutral-900 hover:text-white hover:border-neutral-900 transition-colors">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M9 18l6-6-6-6" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 全寬軌道 -->
    {works.length > 0 ? (
        <div id="featured-track"
             class="overflow-x-auto overflow-y-hidden scroll-smooth [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
            <div class="grid grid-rows-2 grid-flow-col gap-0 auto-cols-[50vw] sm:auto-cols-[33.333vw] lg:auto-cols-[25vw] px-0">
                {works.map((w, i) => (
                    <a href={`/works/${w.slug}`}
                       aria-label={w.title}
                       class="group relative block aspect-video overflow-hidden bg-neutral-900 snap-start">
                        <SmartImage src={thumbs[i]}
                                    alt={w.title}
                                    width={1280} height={720}
                                    widths={[480, 800, 1280]}
                                    sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
                                    loading={i < 4 ? "eager" : "lazy"}
                                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]" />

                        <!-- hover / focus 時浮現標題 -->
                        <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/85 via-black/0 to-transparent opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100 transition-opacity duration-300">
                            <div class="p-4 sm:p-5 text-white text-sm tracking-wide font-medium line-clamp-2">
                                {w.title}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    ) : (
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center text-neutral-500">
            <Tr zh="目前沒有精選作品" en="No featured works yet" />
        </div>
    )}
</section>

<script is:inline>
    (() => {
        const track = document.getElementById('featured-track');
        if (!track) return;
        const buttons = document.querySelectorAll('[data-scroll]');
        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                const dir = btn.getAttribute('data-scroll') === 'next' ? 1 : -1;
                track.scrollBy({ left: dir * track.clientWidth * 0.8, behavior: 'smooth' });
            });
        });
    })();
</script>

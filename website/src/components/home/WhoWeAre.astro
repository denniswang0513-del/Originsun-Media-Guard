---
/**
 * WhoWeAre.astro — 首頁第 2 段：自介 + Showreel 合一
 *
 * 結構（從上到下）：
 *   [max-w-3xl 窄文字]    About 小字
 *                          大標一句
 *                          2-3 行敘述
 *   [max-w-screen-2xl 寬影片]   Showreel 滿版 16:9
 *   [max-w-3xl]          4 欄 stats（不折行）
 *                          了解更多連結
 *
 * 視覺節奏：敘述收斂 → 影片打開 → 數字收尾 + 行動
 */
import Tr from "../ui/Tr.astro";

interface StatItem { value: string; label_zh: string; label_en: string }

interface Props {
    /** Showreel YouTube ID（admin「🏠 首頁設定」可編，預設 DRavYkTojAo） */
    showreel_id?: string;
    /** 4 欄信任數字（admin「🏠 首頁設定」可編，空則用預設） */
    stats?: StatItem[];
    /** admin 可編輯的首頁文案（copy.home.*）；空欄位則用硬寫 fallback。 */
    copy?: Record<string, string>;
}

/** 預設 stats（meta.home_stats 取不到時的 fallback；正常走後端自動真實值） */
const DEFAULT_STATS: StatItem[] = [
    { value: "13",   label_zh: "年製作經驗", label_en: "Years" },
    { value: "150+", label_zh: "完成作品",   label_en: "Projects" },
    { value: "130+", label_zh: "合作品牌",   label_en: "Brands" },
];
const GRID_COLS: Record<number, string> = { 1: "grid-cols-1", 2: "grid-cols-2", 3: "grid-cols-3", 4: "grid-cols-4" };

const { showreel_id = "DRavYkTojAo", stats = [], copy = {} } = Astro.props;

// 數字來自 meta.home_stats（後端自動算真實值：年資/公開作品數/客戶數，admin 可逐欄覆寫）；空則用預設。
const provided: StatItem[] = (stats || []).filter(s => s && s.value);
const shownStats: StatItem[] = provided.length > 0 ? provided : DEFAULT_STATS;
const gridCols = GRID_COLS[shownStats.length] || "grid-cols-3";
---

<section class="bg-white py-24 sm:py-32">

    <!-- 1. 自介文字（窄置中） -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16 sm:mb-20">
        <p class="text-xs tracking-[0.4em] text-[#c9372c] uppercase mb-6">{copy.whoweare_eyebrow ?? "About Us"}</p>

        <h2 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 leading-[1.15] mb-8 whitespace-pre-line">
            <Tr zh={copy.whoweare_heading_zh ?? "我們是源日影像——十多年來，說了上百個品牌故事"}
                en={copy.whoweare_heading_en ?? "We're OriginsunStudio — hundreds of stories over more than a decade"} />
        </h2>

        <p class="max-w-xl mx-auto text-base sm:text-lg text-neutral-600 leading-[1.9] tracking-wide">
            <Tr zh={copy.whoweare_intro_zh ?? "從商業廣告到紀實短片，從活動紀錄到動態設計。一支影片的起點，是長時間的聆聽，而不是按下 REC。"}
                en={copy.whoweare_intro_en ?? "Commercials, documentaries, events, motion graphics — every project starts with listening, not recording."} />
        </p>
    </div>

    <!-- 2. Showreel 置中 + 比上方文字寬約 1.5 倍
         lite-youtube-embed 預設 CSS 有 max-width: 720px，用 inline style 覆寫，
         否則 aspect-video + w-full 會卡在 720px。 -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <lite-youtube videoid={showreel_id}
                      class="block aspect-video w-full"
                      style="max-width: none;"
                      playlabel="Originsun Showreel"></lite-youtube>
    </div>

    <!-- 3. stats + 了解更多 + 創辦人署名 -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center mt-16 sm:mt-20">
        <!-- stats：4 欄不折行 -->
        <ul class={`grid ${gridCols} divide-x divide-neutral-200 mb-12`}>
            {shownStats.map(s => (
                <li class="px-2 sm:px-4 text-center">
                    <div class="text-xl sm:text-3xl font-bold tracking-tight text-neutral-900 leading-none whitespace-nowrap">
                        {s.value}
                    </div>
                    <div class="text-[9px] sm:text-xs tracking-[0.2em] uppercase text-neutral-500 mt-2 sm:mt-3 whitespace-nowrap">
                        <Tr zh={s.label_zh} en={s.label_en} />
                    </div>
                </li>
            ))}
        </ul>

        <a href="/about"
           class="inline-flex items-center gap-3 text-xs tracking-[0.3em] uppercase text-neutral-900 border-b border-[#c9372c] pb-1 hover:text-[#c9372c] transition-colors">
            <Tr zh="了解更多" en="Learn more" />
            <span>→</span>
        </a>
    </div>
</section>

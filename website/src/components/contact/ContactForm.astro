---
/**
 * ContactForm.astro — 聯絡表單（client-side runtime，POST 到 /api/website/contact）
 *
 * 策略：純 static HTML + 一個 inline <script> 處理 submit（不用 React / 框架）。
 * Turnstile widget 用 CF script 載入；若 site_key 空（dev）則用 dummy token。
 */
import { TURNSTILE_SITE_KEY, WEBSITE_API_BASE } from "../../lib/config";
import type { IWebsiteMeta, IFormOption } from "../../types/meta";
import Tr from "../ui/Tr.astro";

interface Props { meta: IWebsiteMeta }
const { meta } = Astro.props;

const hasTurnstile = !!TURNSTILE_SITE_KEY;

// ── admin 可編輯的表單欄位標籤（copy.contact.form_*）；未設用硬寫 fallback ──
const cp = meta.copy?.contact ?? {};

// ── admin 可編輯的選項清單（forms.contact.*）；空 → 硬寫 fallback ──
// IMPORTANT：value 是穩定 token（後端 service_type / budget_range 存這個），只 label 可改。
// 不可變更 value 語意，否則 CRM 對應會壞。
const FALLBACK_SERVICE_TYPES: IFormOption[] = [
    { value: "commercial",  label_zh: "商業廣告・形象影片", label_en: "Commercial & Brand" },
    { value: "documentary", label_zh: "紀實短片・紀錄片",   label_en: "Documentary" },
    { value: "event",       label_zh: "活動紀實",          label_en: "Event" },
    { value: "animation",   label_zh: "動畫製作",          label_en: "Animation" },
    { value: "other",       label_zh: "其他",              label_en: "Other" },
];
const FALLBACK_BUDGET_RANGES: IFormOption[] = [
    { value: "10-30",   label_zh: "10-30 萬",     label_en: "100K–300K" },
    { value: "30-80",   label_zh: "30-80 萬",     label_en: "300K–800K" },
    { value: "80-150",  label_zh: "80-150 萬",    label_en: "800K–1.5M" },
    { value: "150-300", label_zh: "150-300 萬",   label_en: "1.5M–3M" },
    { value: "300+",    label_zh: "300 萬以上",    label_en: "3M+" },
];

const fc = meta.forms?.contact ?? {};
const serviceTypes: IFormOption[] =
    fc.service_types && fc.service_types.length > 0 ? fc.service_types : FALLBACK_SERVICE_TYPES;
const budgetRanges: IFormOption[] =
    fc.budget_ranges && fc.budget_ranges.length > 0 ? fc.budget_ranges : FALLBACK_BUDGET_RANGES;
---

<!-- Turnstile 載入（只在有 site key 時載） -->
{hasTurnstile && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<form id="contact-form"
      data-api-base={WEBSITE_API_BASE}
      data-has-turnstile={hasTurnstile ? "1" : "0"}
      class="space-y-5 max-w-xl mx-auto">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <label class="block">
            <span class="block text-xs tracking-widest uppercase text-neutral-600 mb-2">
                <Tr zh={cp.form_name_zh ?? "姓名"} en={cp.form_name_en ?? "Name"} /> *
            </span>
            <input type="text" name="name" required maxlength="100"
                   class="w-full bg-white border border-neutral-300 text-neutral-900 px-4 py-3 focus:outline-none focus:border-neutral-900 transition-colors" />
        </label>
        <label class="block">
            <span class="block text-xs tracking-widest uppercase text-neutral-600 mb-2">
                <Tr zh={cp.form_email_zh ?? "Email"} en={cp.form_email_en ?? "Email"} /> *
            </span>
            <input type="email" name="email" required maxlength="200"
                   class="w-full bg-white border border-neutral-300 text-neutral-900 px-4 py-3 focus:outline-none focus:border-neutral-900 transition-colors" />
        </label>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <label class="block">
            <span class="block text-xs tracking-widest uppercase text-neutral-600 mb-2">
                <Tr zh={cp.form_phone_zh ?? "電話"} en={cp.form_phone_en ?? "Phone"} />
            </span>
            <input type="tel" name="phone" maxlength="50"
                   class="w-full bg-white border border-neutral-300 text-neutral-900 px-4 py-3 focus:outline-none focus:border-neutral-900 transition-colors" />
        </label>
        <label class="block">
            <span class="block text-xs tracking-widest uppercase text-neutral-600 mb-2">
                <Tr zh={cp.form_company_zh ?? "公司"} en={cp.form_company_en ?? "Company"} />
            </span>
            <input type="text" name="company" maxlength="200"
                   class="w-full bg-white border border-neutral-300 text-neutral-900 px-4 py-3 focus:outline-none focus:border-neutral-900 transition-colors" />
        </label>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <label class="block">
            <span class="block text-xs tracking-widest uppercase text-neutral-600 mb-2">
                <Tr zh={cp.form_service_type_zh ?? "服務類型"} en={cp.form_service_type_en ?? "Service Type"} />
            </span>
            <select name="service_type" data-i18n-select
                    class="w-full bg-white border border-neutral-300 text-neutral-900 px-4 py-3 focus:outline-none focus:border-neutral-900">
                <option value="">—</option>
                {serviceTypes.map(o => (
                    <option value={o.value} data-label-zh={o.label_zh} data-label-en={o.label_en}>{o.label_zh}</option>
                ))}
            </select>
        </label>
        <label class="block">
            <span class="block text-xs tracking-widest uppercase text-neutral-600 mb-2">
                <Tr zh={cp.form_budget_range_zh ?? "預算範圍"} en={cp.form_budget_range_en ?? "Budget Range"} />
            </span>
            <select name="budget_range" data-i18n-select
                    class="w-full bg-white border border-neutral-300 text-neutral-900 px-4 py-3 focus:outline-none focus:border-neutral-900">
                <option value="">—</option>
                {budgetRanges.map(o => (
                    <option value={o.value} data-label-zh={o.label_zh} data-label-en={o.label_en}>{o.label_zh}</option>
                ))}
            </select>
        </label>
    </div>

    <label class="block">
        <span class="block text-xs tracking-widest uppercase text-neutral-600 mb-2">
            <Tr zh={cp.form_message_zh ?? "訊息"} en={cp.form_message_en ?? "Message"} /> *
        </span>
        <textarea name="message" required rows="5" maxlength="5000"
                  class="w-full bg-white border border-neutral-300 text-neutral-900 px-4 py-3 focus:outline-none focus:border-neutral-900 transition-colors resize-y"></textarea>
    </label>

    {hasTurnstile && (
        <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light"></div>
    )}

    <div class="flex flex-col sm:flex-row gap-4 items-center pt-2">
        <button type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 text-sm tracking-widest uppercase bg-neutral-900 text-white px-10 py-4 hover:bg-[#c9372c] disabled:bg-neutral-400 disabled:cursor-not-allowed transition-colors">
            <span data-btn-text><Tr zh="送出" en="Send" /></span>
            <span>→</span>
        </button>
        <div id="contact-status" class="text-sm" aria-live="polite"></div>
    </div>

    <p class="text-xs text-neutral-500 tracking-wide pt-2">
        <Tr zh="送出即同意我們可以用您提供的聯絡資訊回覆。我們不會將您的資訊用於其他用途。"
            en="By submitting, you agree we may use your contact info to reply. We won't use it for other purposes." />
    </p>
</form>

<script>
// 雙語 <option> 文字切換：<option> 內不能放 span（HTML 只渲染文字），所以改用
// data-label-zh / data-label-en 屬性 + 監聽 html[data-lang] 切換時改寫 option.textContent。
// 預設（首次 render / zh）= label_zh，與舊站 zh-only 選項行為一致。
function _syncSelectLang() {
    const lang = document.documentElement.getAttribute("data-lang") === "en" ? "en" : "zh";
    document.querySelectorAll<HTMLOptionElement>("[data-i18n-select] option[data-label-zh]").forEach(opt => {
        const txt = lang === "en" ? opt.dataset.labelEn : opt.dataset.labelZh;
        if (txt) opt.textContent = txt;
    });
}
_syncSelectLang();
new MutationObserver(_syncSelectLang).observe(document.documentElement, {
    attributes: true, attributeFilter: ["data-lang"],
});

const form = document.getElementById("contact-form") as HTMLFormElement | null;
if (form) {
    const statusEl = document.getElementById("contact-status");
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    const btnText = form.querySelector("[data-btn-text]");
    const originalText = btnText?.innerHTML;
    const apiBase = form.dataset.apiBase || "";
    const hasTurnstile = form.dataset.hasTurnstile === "1";

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!statusEl || !btn) return;

        btn.disabled = true;
        statusEl.textContent = "";
        statusEl.className = "text-sm text-neutral-400";
        if (btnText) btnText.innerHTML = "傳送中…";

        try {
            const fd = new FormData(form);
            let turnstileToken = "dev";
            if (hasTurnstile) {
                const tsResp = (fd.get("cf-turnstile-response") || "").toString();
                if (!tsResp) throw new Error("請完成機器人驗證");
                turnstileToken = tsResp;
            }

            const payload: Record<string, string> = { turnstile_token: turnstileToken };
            for (const [k, v] of fd.entries()) {
                if (k === "cf-turnstile-response") continue;
                const s = v.toString().trim();
                if (s) payload[k] = s;
            }
            payload.source = window.location.pathname;

            const res = await fetch(`${apiBase}/api/website/contact`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
            });

            if (!res.ok) {
                const errData = await res.json().catch(() => ({}));
                const detail = (errData as { detail?: string }).detail || `HTTP ${res.status}`;
                throw new Error(typeof detail === "string" ? detail : JSON.stringify(detail));
            }

            statusEl.textContent = "✓ 已送出，我們會在 1-2 個工作天內回覆您";
            statusEl.className = "text-sm text-green-400";
            form.reset();
            if ((window as unknown as { turnstile?: { reset: () => void } }).turnstile) {
                (window as unknown as { turnstile: { reset: () => void } }).turnstile.reset();
            }
        } catch (err) {
            const msg = err instanceof Error ? err.message : String(err);
            statusEl.textContent = `✕ 送出失敗：${msg}`;
            statusEl.className = "text-sm text-red-400";
        } finally {
            btn.disabled = false;
            if (btnText && originalText) btnText.innerHTML = originalText;
        }
    });
}
</script>

---
/**
 * portfolio.astro — 歷年作品一頁式清單（/portfolio）
 *
 * 設計目的：客戶主管參考用的列印簡介。
 * 極簡路線：單欄、純文字、時間軸。
 *
 * 結構：
 *   [頁首]   標題 + 列印按鈕
 *   [列印頁首]  公司名 + 聯絡（僅列印時顯示）
 *   [時間軸]  年份大字 + 該年作品清單（客戶 — 標題）
 *   [列印頁尾]  © 公司名 + 網址
 *
 * @media print：隱藏 nav/footer/button，單色列印、不分頁符。
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Tr from "../components/ui/Tr.astro";
import { fetchMeta, fetchAllWorksCached } from "../lib/crm-client";
import type { IPublicProject } from "../types/project";

const [meta, allWorks] = await Promise.all([
    fetchMeta(),
    fetchAllWorksCached(),
]);

// 年份分組（desc，無年份放最後）
function groupByYear(works: IPublicProject[]): Array<{ year: number | null; works: IPublicProject[] }> {
    const m = new Map<number | null, IPublicProject[]>();
    for (const w of works) {
        const y = w.year ?? null;
        if (!m.has(y)) m.set(y, []);
        m.get(y)!.push(w);
    }
    return Array.from(m.entries())
        .sort((a, b) => {
            if (a[0] === null) return 1;
            if (b[0] === null) return -1;
            return b[0] - a[0];
        })
        .map(([year, works]) => ({ year, works }));
}

const years = groupByYear(allWorks);
const totalCount = allWorks.length;
---

<BaseLayout title="歷年作品 Portfolio" meta={meta}>

    <!-- 頁首：標題 + 列印按鈕（列印時隱藏） -->
    <section class="bg-white pt-28 sm:pt-32 pb-12 print:hidden">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <p class="text-xs tracking-[0.4em] text-neutral-500 uppercase mb-3">Portfolio</p>
            <div class="flex items-end justify-between flex-wrap gap-4">
                <div>
                    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-neutral-900 mb-3">
                        <Tr zh="歷年作品" en="Our Portfolio" />
                    </h1>
                    <p class="text-neutral-600 tracking-wide">
                        <Tr zh={`${meta.company_name_zh} 歷年製作一覽（共 ${totalCount} 件）`}
                            en={`A chronological list from ${meta.company_name_en} — ${totalCount} projects`} />
                    </p>
                </div>
                <button type="button" onclick="window.print()"
                        class="inline-flex items-center gap-2 text-xs tracking-[0.25em] uppercase border border-neutral-900 text-neutral-900 px-5 py-2 hover:bg-neutral-900 hover:text-white transition-colors">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z" />
                    </svg>
                    <Tr zh="列印 / 另存 PDF" en="Print / Save PDF" />
                </button>
            </div>
        </div>
    </section>

    <!-- 列印專用頁首 -->
    <div class="hidden print:block mb-6 pb-4 border-b border-neutral-300 mx-8 mt-4">
        <div class="flex justify-between items-start">
            <div>
                <div class="text-xl font-bold text-neutral-900">{meta.company_name_zh}</div>
                <div class="text-xs text-neutral-600 tracking-widest">{meta.company_name_en} · Portfolio</div>
            </div>
            <div class="text-right text-xs text-neutral-600">
                {meta.phone && <div>Tel: {meta.phone}</div>}
                {meta.email && <div>{meta.email}</div>}
                {meta.address && <div>{meta.address}</div>}
            </div>
        </div>
    </div>

    <!-- 時間軸主體（單欄、純文字） -->
    <section class="bg-white pb-20 print:pb-0">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            {years.map(yg => (
                <div class="mb-12 print:mb-6 print:break-inside-avoid">
                    <!-- 年份標 -->
                    <div class="flex items-center gap-4 mb-6 print:mb-3">
                        <span class="text-3xl sm:text-4xl font-bold tracking-tight text-[#c9372c]">
                            {yg.year ?? "—"}
                        </span>
                        <span class="flex-1 h-px bg-neutral-200"></span>
                        <span class="text-xs tracking-[0.25em] uppercase text-neutral-400">
                            {yg.works.length} <Tr zh="件" en="works" />
                        </span>
                    </div>

                    <!-- 作品清單（一行一件：客戶 — 標題） -->
                    <ul class="space-y-2.5 print:space-y-1">
                        {yg.works.map(w => (
                            <li class="grid grid-cols-[auto_1fr] gap-x-4 text-[15px] leading-relaxed">
                                <span class="text-neutral-900 font-medium tracking-wide min-w-[8em]">
                                    {w.client || "—"}
                                </span>
                                <a href={`/works/${w.slug}`}
                                   class="text-neutral-600 tracking-wide hover:text-[#c9372c] transition-colors print:pointer-events-none">
                                    {w.title}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
    </section>

    <!-- 列印頁尾 -->
    <div class="hidden print:block mt-6 pt-4 border-t border-neutral-300 text-xs text-neutral-600 text-center mx-8">
        © {new Date().getFullYear()} {meta.company_name_zh} {meta.company_name_en} · originsun-studio.com
    </div>
</BaseLayout>

<style>
    @media print {
        :global(header[id="site-header"]), :global(footer) {
            display: none !important;
        }
        :global(body) {
            background: white !important;
            color: #111 !important;
            font-size: 10.5pt;
        }
        a { color: #111 !important; text-decoration: none !important; }
    }
</style>

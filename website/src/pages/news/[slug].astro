---
/**
 * news/[slug].astro — 專欄文章詳情頁
 */
import SmartImage from "../../components/ui/SmartImage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tr from "../../components/ui/Tr.astro";
import PostBody from "../../components/blog/PostBody.astro";
import { renderInline } from "../../lib/richtext";
import { fetchMeta } from "../../lib/crm-client";
import { fetchPosts, fetchPostBySlug } from "../../lib/posts";
import { pageSchemas, resolveSiteUrl, ensureMinDescription, breadcrumb3 } from "../../lib/seo";

export async function getStaticPaths() {
    const posts = await fetchPosts();
    return posts.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const [meta, post, allPosts] = await Promise.all([
    fetchMeta(),
    fetchPostBySlug(slug!),
    fetchPosts(),
]);

if (!post) return Astro.redirect("/news");

// 下一篇 / 前一篇（同分類優先，否則整體）
const sameCat = allPosts.filter(p => p.category === post.category && p.slug !== post.slug);
const pool = sameCat.length > 0 ? sameCat : allPosts.filter(p => p.slug !== post.slug);
const related = pool.slice(0, 3);

const publishedDate = new Date(post.published_at).toLocaleDateString("zh-TW", {
    year: "numeric", month: "long", day: "numeric",
});

const siteUrl = resolveSiteUrl(Astro.site);
// SEO 覆寫優先序（對齊 works/[slug].astro）：AI/admin 寫的 seo_* > 內文 fallback
const description = ensureMinDescription(
    post.seo_description || post.excerpt,
    `${post.title} — ${meta.company_name_zh}影像專欄 Insight，分享影像製作幕後與業界觀察。`,
);
const pageTitle = post.seo_title || post.title;

// AI SEO 生成的 FAQ → FAQPage 結構化資料 + 文章底部可見區段
const faqs = (post.faqs ?? []).filter(f => f && f.q && f.a);
const schemaData = [
    pageSchemas.newsArticle(post, meta, siteUrl),
    pageSchemas.breadcrumb(breadcrumb3("影像專欄", "/news", post.title, `/news/${post.slug}`), siteUrl),
    ...(faqs.length > 0
        ? [pageSchemas.faqPage(faqs.map(f => ({ question: f.q, answer: f.a })))]
        : []),
];

// 內文雙語：body_en 有內容則用之，否則 fallback 中文 body。
// 兩個 data-lang 容器並存（CSS 依 html[data-lang] 控顯隱，與 Tr 同機制），共用 PostBody。
const bodyZh = post.body ?? [];
const bodyEn = (post.body_en && post.body_en.length > 0) ? post.body_en : bodyZh;
---

<BaseLayout title={pageTitle}
            description={description}
            meta={meta}
            schemaData={schemaData}
            ogImage={post.cover_url}>

    <!-- Hero cover -->
    <section class="pt-24 sm:pt-28 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="aspect-[16/9] overflow-hidden bg-neutral-100">
                <SmartImage src={post.cover_url} alt={post.title}
                            width={1280} height={720}
                            widths={[400, 800, 1280, 1920]}
                            sizes="(max-width: 768px) 100vw, 1280px"
                            loading="eager"
                            class="w-full h-full object-cover" />
            </div>
        </div>
    </section>

    <!-- 類別 + 標題 + meta -->
    <article class="bg-white pt-12 sm:pt-16 pb-8">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-xs tracking-[0.4em] uppercase text-[#c9372c] mb-5">
                <Tr zh={post.category_label_zh} en={post.category_label_en} />
            </div>

            <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 mb-6 leading-tight">
                <Tr zh={post.title} en={post.title_en || post.title} />
            </h1>

            <div class="flex items-center gap-4 text-xs tracking-widest text-neutral-500 mb-4">
                <span>{publishedDate}</span>
                {post.read_time_min && <>
                    <span>·</span>
                    <span><Tr zh={`${post.read_time_min} 分鐘閱讀`} en={`${post.read_time_min} min read`} /></span>
                </>}
            </div>
        </div>
    </article>

    <!-- 內文 blocks（中英雙容器並存，CSS 依 data-lang 顯隱其一；共用 PostBody） -->
    <article class="bg-white pb-16 sm:pb-24 post-body">
        <div data-lang-zh><PostBody blocks={bodyZh} fallbackText={post.excerpt} /></div>
        <div data-lang-en><PostBody blocks={bodyEn} fallbackText={post.excerpt_en || post.excerpt} /></div>
    </article>

    <!-- 常見問題（AI SEO 生成；同時輸出 FAQPage JSON-LD） -->
    {faqs.length > 0 && (
        <section class="bg-white pb-4 sm:pb-8">
            <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-2xl sm:text-3xl font-bold text-neutral-900 mb-8 tracking-tight">
                    <Tr zh="常見問題" en="FAQ" />
                </h2>
                <div class="divide-y divide-neutral-200 border-t border-neutral-200">
                    {faqs.map(f => (
                        <details class="group py-5">
                            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
                                <h3 class="text-base sm:text-lg font-semibold text-neutral-900 leading-snug">{f.q}</h3>
                                <span class="mt-1 text-[#c9372c] text-xl leading-none transition-transform group-open:rotate-45">+</span>
                            </summary>
                            <p class="mt-3 text-[15px] sm:text-base text-neutral-700 leading-[1.85] tracking-wide"
                               set:html={renderInline(f.a)} />
                        </details>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- 底部分隔 -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <hr class="border-neutral-200" />
    </div>

    <!-- 相關文章 -->
    {related.length > 0 && (
        <section class="bg-neutral-50 py-16 mt-8">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-xs tracking-[0.4em] uppercase text-neutral-500 mb-8 text-center">
                    <Tr zh="更多文章" en="More Articles" />
                </h2>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
                    {related.map(p => (
                        <a href={`/news/${p.slug}`} class="group block">
                            <div class="relative overflow-hidden aspect-video bg-neutral-200 mb-3">
                                <SmartImage src={p.cover_url} alt={p.title}
                                            width={800} height={450}
                                            widths={[400, 800]}
                                            sizes="(max-width: 640px) 100vw, 33vw"
                                            loading="lazy"
                                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
                            </div>
                            <div class="text-[10px] tracking-[0.3em] uppercase text-[#c9372c] mb-1">
                                {p.category_label_en}
                            </div>
                            <h3 class="text-base font-medium text-neutral-900 leading-snug group-hover:text-[#c9372c] transition-colors">
                                <Tr zh={p.title} en={p.title_en || p.title} />
                            </h3>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    )}
</BaseLayout>

<style>
    /* 段落之間視覺節奏：第一段與標題連動時收斂上邊距 */
    .post-body h2 + div p,
    .post-body h3 + div p { margin-top: 0; }
</style>

---
/**
 * news/[slug].astro — 專欄文章詳情頁
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tr from "../../components/ui/Tr.astro";
import { fetchMeta } from "../../lib/crm-client";
import { fetchPosts, fetchPostBySlug } from "../../lib/posts";
import { isValidYouTubeId } from "../../lib/youtube";
import { pageSchemas, resolveSiteUrl, ensureMinDescription, breadcrumb3 } from "../../lib/seo";
import type { PostBlockWidth } from "../../types/post";

const WIDTH_CLASS: Record<PostBlockWidth, string> = {
    content: "max-w-[680px]",
    wide:    "max-w-4xl",
    full:    "max-w-none",
};

// notion_service 把 paragraph/quote/list 內的 inline 連結存成 markdown `[text](url)`。
// 這個 helper 把那段 markdown 還原成 <a>。content 已是 Notion 來的可信來源，但仍
// HTML-escape 文字部分 + URL attr，避免奇怪字元意外注入 markup。
const _ESC = (s: string) => s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
const _MD_LINK = /\[([^\]]+)\]\(([^)\s]+)\)/g;
function renderInline(text: string): string {
    if (!text) return "";
    // 先全文 escape，避免 < & " 等出現在 plain text 時破壞渲染
    const escaped = _ESC(text);
    // 再把 markdown link 模式還原（_ESC 不會碰到 [ ] ( ) 等字元，所以模式仍可匹配）
    return escaped.replace(_MD_LINK, (_, label, href) =>
        `<a href="${_ESC(href)}" target="_blank" rel="noopener noreferrer" class="text-[#c9372c] underline hover:text-[#a02a23]">${label}</a>`
    );
}

export async function getStaticPaths() {
    const posts = await fetchPosts();
    return posts.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const [meta, post, allPosts] = await Promise.all([
    fetchMeta(),
    fetchPostBySlug(slug!),
    fetchPosts(),
]);

if (!post) return Astro.redirect("/news");

// 下一篇 / 前一篇（同分類優先，否則整體）
const sameCat = allPosts.filter(p => p.category === post.category && p.slug !== post.slug);
const pool = sameCat.length > 0 ? sameCat : allPosts.filter(p => p.slug !== post.slug);
const related = pool.slice(0, 3);

const publishedDate = new Date(post.published_at).toLocaleDateString("zh-TW", {
    year: "numeric", month: "long", day: "numeric",
});

const siteUrl = resolveSiteUrl(Astro.site);
const description = ensureMinDescription(
    post.excerpt,
    `${post.title} — ${meta.company_name_zh}影像專欄 Insight，分享影像製作幕後與業界觀察。`,
);
const schemaData = [
    pageSchemas.newsArticle(post, meta, siteUrl),
    pageSchemas.breadcrumb(breadcrumb3("影像專欄", "/news", post.title, `/news/${post.slug}`), siteUrl),
];
---

<BaseLayout title={post.title}
            description={description}
            meta={meta}
            schemaData={schemaData}
            ogImage={post.cover_url}>

    <!-- Hero cover -->
    <section class="pt-24 sm:pt-28 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="aspect-[16/9] overflow-hidden bg-neutral-100">
                <img src={post.cover_url} alt={post.title}
                     width="1280" height="720"
                     class="w-full h-full object-cover" />
            </div>
        </div>
    </section>

    <!-- 類別 + 標題 + meta -->
    <article class="bg-white pt-12 sm:pt-16 pb-8">
        <div class="max-w-[680px] mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-xs tracking-[0.4em] uppercase text-[#c9372c] mb-5">
                <Tr zh={post.category_label_zh} en={post.category_label_en} />
            </div>

            <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-neutral-900 mb-6 leading-tight">
                {post.title}
            </h1>

            <div class="flex items-center gap-4 text-xs tracking-widest text-neutral-500 mb-4">
                <span>{publishedDate}</span>
                {post.read_time_min && <>
                    <span>·</span>
                    <span><Tr zh={`${post.read_time_min} 分鐘閱讀`} en={`${post.read_time_min} min read`} /></span>
                </>}
            </div>
        </div>
    </article>

    <!-- 內文 blocks -->
    <article class="bg-white pb-16 sm:pb-24 post-body">
        {post.body && post.body.length > 0 ? (
            post.body.map(block => {
                if (block.type === "paragraph") {
                    const size = block.lead ? "text-xl sm:text-2xl text-neutral-800 leading-[1.7]" : "text-[17px] sm:text-lg text-neutral-700 leading-[1.95]";
                    return (
                        <div class="max-w-[680px] mx-auto px-4 sm:px-6 lg:px-8 my-6">
                            <p class={`${size} tracking-wide`} set:html={renderInline(block.text)} />
                        </div>
                    );
                }
                if (block.type === "heading") {
                    const cls = block.level === 2
                        ? "text-2xl sm:text-3xl font-bold text-neutral-900 mt-14 mb-4 tracking-tight"
                        : "text-xl sm:text-2xl font-semibold text-neutral-900 mt-10 mb-3 tracking-tight";
                    return (
                        <div class="max-w-[680px] mx-auto px-4 sm:px-6 lg:px-8">
                            {block.level === 2 ? <h2 class={cls}>{block.text}</h2> : <h3 class={cls}>{block.text}</h3>}
                        </div>
                    );
                }
                if (block.type === "image") {
                    const widthCls = WIDTH_CLASS[block.width ?? "content"];
                    return (
                        <figure class={`${widthCls} mx-auto px-4 sm:px-6 lg:px-8 my-10 sm:my-14`}>
                            <img src={block.src} alt={block.alt ?? ""} loading="lazy"
                                 class="w-full h-auto" />
                            {block.caption && (
                                <figcaption class="text-xs text-neutral-500 tracking-wide mt-3 text-center">
                                    {block.caption}
                                </figcaption>
                            )}
                        </figure>
                    );
                }
                if (block.type === "video") {
                    const widthCls = WIDTH_CLASS[block.width ?? "content"];
                    return (
                        <figure class={`${widthCls} mx-auto px-4 sm:px-6 lg:px-8 my-10 sm:my-14`}>
                            {isValidYouTubeId(block.youtube_id) ? (
                                <lite-youtube videoid={block.youtube_id}
                                              class="block aspect-video"
                                              playlabel={block.caption ?? "Play video"}></lite-youtube>
                            ) : (
                                <div class="aspect-video bg-neutral-100 flex items-center justify-center text-neutral-400 text-sm">
                                    影片無法載入
                                </div>
                            )}
                            {block.caption && (
                                <figcaption class="text-xs text-neutral-500 tracking-wide mt-3 text-center">
                                    {block.caption}
                                </figcaption>
                            )}
                        </figure>
                    );
                }
                if (block.type === "quote") {
                    return (
                        <div class="max-w-[680px] mx-auto px-4 sm:px-6 lg:px-8 my-10 sm:my-14">
                            <blockquote class="border-l-2 border-[#c9372c] pl-6 sm:pl-8 py-2">
                                <p class="text-xl sm:text-2xl font-light text-neutral-800 leading-[1.6] tracking-wide italic"
                                   set:html={`「${renderInline(block.text)}」`} />
                                {block.author && (
                                    <cite class="block not-italic text-xs tracking-[0.3em] uppercase text-neutral-500 mt-4">
                                        — {block.author}
                                    </cite>
                                )}
                            </blockquote>
                        </div>
                    );
                }
                if (block.type === "list") {
                    const Tag = block.ordered ? "ol" : "ul";
                    const listCls = block.ordered ? "list-decimal" : "list-disc";
                    return (
                        <div class="max-w-[680px] mx-auto px-4 sm:px-6 lg:px-8 my-6">
                            <Tag class={`${listCls} pl-6 space-y-2 text-[17px] sm:text-lg text-neutral-700 leading-[1.85] tracking-wide marker:text-[#c9372c]`}>
                                {block.items.map(item => <li set:html={renderInline(item)} />)}
                            </Tag>
                        </div>
                    );
                }
                return null;
            })
        ) : (
            <div class="max-w-[680px] mx-auto px-4 sm:px-6 lg:px-8">
                <p class="text-lg text-neutral-600 leading-[1.85] tracking-wide">{post.excerpt}</p>
            </div>
        )}
    </article>

    <!-- 底部分隔 -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <hr class="border-neutral-200" />
    </div>

    <!-- 相關文章 -->
    {related.length > 0 && (
        <section class="bg-neutral-50 py-16 mt-8">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-xs tracking-[0.4em] uppercase text-neutral-500 mb-8 text-center">
                    <Tr zh="更多文章" en="More Articles" />
                </h2>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
                    {related.map(p => (
                        <a href={`/news/${p.slug}`} class="group block">
                            <div class="relative overflow-hidden aspect-video bg-neutral-200 mb-3">
                                <img src={p.cover_url} alt={p.title}
                                     class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
                            </div>
                            <div class="text-[10px] tracking-[0.3em] uppercase text-[#c9372c] mb-1">
                                {p.category_label_en}
                            </div>
                            <h3 class="text-base font-medium text-neutral-900 leading-snug group-hover:text-[#c9372c] transition-colors">
                                {p.title}
                            </h3>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    )}
</BaseLayout>

<style>
    /* 段落之間視覺節奏：第一段與標題連動時收斂上邊距 */
    .post-body h2 + div p,
    .post-body h3 + div p { margin-top: 0; }
</style>

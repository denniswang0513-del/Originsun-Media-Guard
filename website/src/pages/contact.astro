---
/**
 * contact.astro — 聯絡頁（/contact）
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Tr from "../components/ui/Tr.astro";
import ContactForm from "../components/contact/ContactForm.astro";
import { fetchMeta } from "../lib/crm-client";
import { buildBasicPageSeo, breadcrumb2 } from "../lib/seo";

const meta = await fetchMeta();

const seo = buildBasicPageSeo(Astro, {
    title: "聯絡我們 Contact",
    description: `聯絡${meta.company_name_zh} — 商業影片製作、報價諮詢、合作邀約。台北市中山區，1-2 個工作天內回覆，安排第一次諮詢。`,
    breadcrumbs: breadcrumb2("聯絡我們", "/contact"),
});
---

<BaseLayout {...seo} meta={meta}>
    <section class="pt-32 pb-16 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <p class="text-xs tracking-[0.4em] text-neutral-500 uppercase mb-3">Contact</p>
            <h1 class="text-4xl sm:text-6xl font-light tracking-tight mb-6">
                <Tr zh="聯絡我們" en="Let's Talk" />
            </h1>
            <p class="max-w-2xl mx-auto text-neutral-500 leading-relaxed tracking-wide">
                <Tr zh="告訴我們您的需求，我們會在 1-2 個工作天內回覆，安排第一次諮詢。"
                    en="Tell us about your project. We'll reply within 1-2 business days to schedule a first call." />
            </p>
        </div>
    </section>

    <section class="bg-white pb-20">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <ContactForm />
        </div>
    </section>

    <!-- 快速聯絡管道 -->
    <section class="bg-neutral-50 py-16">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h3 class="text-xs tracking-[0.4em] uppercase text-neutral-500 mb-6 text-center">
                <Tr zh="也可直接聯絡" en="Or reach us directly" />
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
                {meta.phone && (
                    <a href={`tel:${meta.phone}`} class="block p-6 border border-neutral-200 hover:border-neutral-400 hover:text-[#c9372c] transition-colors">
                        <div class="text-2xl mb-2 text-neutral-500">☎</div>
                        <div class="text-xs tracking-widest uppercase text-neutral-500 mb-1">
                            <Tr zh="電話" en="Phone" />
                        </div>
                        <div class="text-neutral-900">{meta.phone}</div>
                    </a>
                )}
                {meta.email && (
                    <a href={`mailto:${meta.email}`} class="block p-6 border border-neutral-200 hover:border-neutral-400 hover:text-[#c9372c] transition-colors">
                        <div class="text-2xl mb-2 text-neutral-500">✉</div>
                        <div class="text-xs tracking-widest uppercase text-neutral-500 mb-1">Email</div>
                        <div class="text-neutral-900">{meta.email}</div>
                    </a>
                )}
                {meta.address && (
                    <div class="block p-6 border border-neutral-200">
                        <div class="text-2xl mb-2 text-neutral-500">◎</div>
                        <div class="text-xs tracking-widest uppercase text-neutral-500 mb-1">
                            <Tr zh="地址" en="Address" />
                        </div>
                        <div class="text-neutral-900 text-sm">{meta.address}</div>
                    </div>
                )}
            </div>
        </div>
    </section>
</BaseLayout>

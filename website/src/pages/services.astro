---
/**
 * services.astro — 服務項目總覽頁（/services）
 * 比首頁的 ServicesGrid 多了長文案 + 不限於 4 項的排版
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Tr from "../components/ui/Tr.astro";
import { fetchMeta, fetchServices, fetchCategories } from "../lib/crm-client";
import { iconChar, warnUnknownIcons } from "../lib/service-icons";
import { buildBasicPageSeo, breadcrumb2, pageSchemas, resolveSiteUrl } from "../lib/seo";

const [meta, services, categories] = await Promise.all([
    fetchMeta(),
    fetchServices(),
    fetchCategories(),
]);

const catBySlug = new Map(categories.map(c => [c.slug, c]));
warnUnknownIcons(services.map(s => s.icon), "services.astro");

const siteUrl = resolveSiteUrl(Astro.site);
const seo = buildBasicPageSeo(Astro, {
    title: "服務項目 Services",
    description: `${meta.company_name_zh}服務項目 — 商業廣告、紀錄片、活動紀錄、動畫設計一條龍製作。從前期腳本發想到後期交付，台北中山專業影像團隊。`,
    breadcrumbs: breadcrumb2("服務項目", "/services"),
});
// 每個服務一個 Service schema → Google 服務搜尋
seo.schemaData.push(...services.map(s => pageSchemas.service(s, meta, siteUrl)));

// admin 可編輯的頁面文案（copy.services.*）；未設則用以下硬寫 fallback。
const cp = meta.copy?.services ?? {};
---

<BaseLayout {...seo} meta={meta}>
    <section class="pt-32 pb-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <p class="text-xs tracking-[0.4em] text-neutral-500 uppercase mb-3">{cp.hero_eyebrow ?? "Services"}</p>
                <h1 class="text-4xl sm:text-5xl font-light tracking-tight mb-6">
                    <Tr zh={cp.hero_title_zh ?? "我們能為您做的"} en={cp.hero_title_en ?? "What We Can Do"} />
                </h1>
                <p class="max-w-2xl mx-auto text-neutral-600 leading-relaxed tracking-wide">
                    <Tr zh={cp.hero_intro_zh ?? "從前期腳本發想到後期交付，一條龍完成您的影像需求。"}
                        en={cp.hero_intro_en ?? "End-to-end production from concept development to final delivery."} />
                </p>
            </div>

            {services.length === 0 ? (
                <div class="py-20 text-center text-neutral-500">
                    <Tr zh="服務項目載入中…" en="Loading services…" />
                </div>
            ) : (
                <div class="space-y-px bg-neutral-200">
                    {services.map(s => {
                        const cat = s.related_category_slug ? catBySlug.get(s.related_category_slug) : null;
                        return (
                            <article class="bg-white p-8 md:p-12 grid grid-cols-1 md:grid-cols-[80px_1fr_auto] gap-6 md:gap-10 items-start">
                                <div class="text-5xl text-neutral-500">{iconChar(s.icon)}</div>
                                <div>
                                    <h2 class="text-2xl font-light tracking-wide mb-3">{s.title}</h2>
                                    {s.short_desc && (
                                        <p class="text-neutral-700 leading-relaxed tracking-wide mb-2">{s.short_desc}</p>
                                    )}
                                </div>
                                {cat && (
                                    <a href={`/works?category=${cat.slug}`}
                                       class="md:self-center inline-flex items-center gap-2 text-xs tracking-widest uppercase border border-neutral-900 px-5 py-2 hover:bg-white hover:text-white hover:border-white transition-colors whitespace-nowrap">
                                        <Tr zh={`看 ${cat.name_zh} 作品`} en={`View ${cat.name_en || cat.name_zh}`} />
                                        <span>→</span>
                                    </a>
                                )}
                            </article>
                        );
                    })}
                </div>
            )}
        </div>
    </section>

    <!-- CTA 區塊 -->
    <section class="bg-neutral-50 py-20">
        <div class="max-w-3xl mx-auto px-4 text-center">
            <h2 class="text-2xl sm:text-3xl font-light tracking-tight mb-6">
                <Tr zh={cp.cta_heading_zh ?? "有影像製作需求？"} en={cp.cta_heading_en ?? "Have a Project in Mind?"} />
            </h2>
            <p class="text-neutral-600 mb-8 tracking-wide">
                <Tr zh={cp.cta_body_zh ?? "不論是品牌形象片、紀實短片或活動紀錄，我們都樂意傾聽您的想法。"}
                    en={cp.cta_body_en ?? "From brand films to documentaries and event recaps — we'd love to hear your story."} />
            </p>
            <a href="/contact"
               class="inline-flex items-center gap-2 text-sm tracking-widest uppercase border border-neutral-500 px-8 py-3 hover:bg-white hover:text-white transition-colors">
                <Tr zh={cp.cta_button_zh ?? "聯絡我們"} en={cp.cta_button_en ?? "Get in Touch"} />
                <span>→</span>
            </a>
        </div>
    </section>
</BaseLayout>

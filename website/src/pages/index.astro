---
/**
 * index.astro — 首頁（/）
 * 組合：Hero（YouTube 背景）+ Featured Works + Services
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeSlideshow from "../components/home/HomeSlideshow.astro";
import FeaturedWorks from "../components/home/FeaturedWorks.astro";
import ServicesGrid from "../components/home/ServicesGrid.astro";
import { fetchMeta, fetchFeatured, fetchServices } from "../lib/crm-client";
import { organizationSchema } from "../lib/seo";
import { LIMITS, SITE_URL_FALLBACK } from "../lib/config";

const [meta, featured, services] = await Promise.all([
    fetchMeta(),
    fetchFeatured(LIMITS.HOME_FEATURED),
    fetchServices(),
]);

const siteUrl = Astro.site?.toString() || SITE_URL_FALLBACK;
const schemaData = [organizationSchema(meta, siteUrl)];
---

<BaseLayout title={meta.company_name_zh}
            description={meta.seo_default_description}
            meta={meta}
            schemaData={schemaData}>
    <HomeSlideshow works={featured} />
    <FeaturedWorks works={featured} />
    <ServicesGrid services={services} />
</BaseLayout>

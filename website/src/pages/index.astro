---
/**
 * index.astro — 首頁（/）
 *
 * Hero 後 9 段：
 *   01 Hero slideshow       — 震撼入場
 *   02 WhoWeAre             — 自介 + 數字 + Showreel + 創辦人署名（合一）
 *   03 ServicesWithCounts   — 4 服務 × 各自專案數
 *   04 FeaturedWorks        — 3×3 精選作品（正方形）
 *   05 ProcessNumbered      — /01-04 流程
 *   06 Testimonials         — 客戶證言 + 4.9 評分
 *   07 HomeInsight          — 3 篇最新專欄
 *   08 FAQ                  — 6 題常見問題
 *   09 ContactCTA           — 深色卡 + 寫訊息
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeSlideshow from "../components/home/HomeSlideshow.astro";
import WhoWeAre from "../components/home/WhoWeAre.astro";
import ServicesWithCounts from "../components/home/ServicesWithCounts.astro";
import FeaturedWorks from "../components/home/FeaturedWorks.astro";
import ProcessNumbered from "../components/home/ProcessNumbered.astro";
import Testimonials from "../components/home/Testimonials.astro";
import HomeInsight from "../components/home/HomeInsight.astro";
import FAQ from "../components/home/FAQ.astro";
import ContactCTA from "../components/home/ContactCTA.astro";
import { fetchMeta, fetchFeatured } from "../lib/crm-client";
import { organizationSchema } from "../lib/seo";
import { LIMITS, SITE_URL_FALLBACK } from "../lib/config";

const [meta, featured] = await Promise.all([
    fetchMeta(),
    fetchFeatured(LIMITS.HOME_FEATURED),
]);

// Show real published works only — no FAKE_FEATURED padding. The grid
// layout collapses gracefully when fewer than 9 works are returned.
const featured9 = featured.slice(0, 9);

const siteUrl = Astro.site?.toString() || SITE_URL_FALLBACK;
const schemaData = [organizationSchema(meta, siteUrl)];
---

<BaseLayout title={meta.company_name_zh}
            description={meta.seo_default_description}
            meta={meta}
            schemaData={schemaData}>
    <HomeSlideshow works={featured} />
    <WhoWeAre />
    <ServicesWithCounts />
    <FeaturedWorks works={featured9} />
    <ProcessNumbered />
    <Testimonials />
    <HomeInsight />
    <FAQ />
    <ContactCTA meta={meta} />
</BaseLayout>

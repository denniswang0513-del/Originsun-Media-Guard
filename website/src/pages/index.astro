---
/**
 * index.astro — 首頁（/）
 *
 * Hero 後 9 段：
 *   01 Hero slideshow       — 震撼入場
 *   02 WhoWeAre             — 自介 + 數字 + Showreel + 創辦人署名（合一）
 *   03 ServicesWithCounts   — 4 服務 × 各自專案數
 *   04 FeaturedWorks        — 3×3 精選作品（正方形）
 *   05 ProcessNumbered      — /01-04 流程
 *   06 Testimonials         — 客戶證言 + 4.9 評分
 *   07 HomeInsight          — 3 篇最新專欄
 *   08 FAQ                  — 6 題常見問題
 *   09 ContactCTA           — 深色卡 + 寫訊息
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeSlideshow from "../components/home/HomeSlideshow.astro";
import WhoWeAre from "../components/home/WhoWeAre.astro";
import ServicesWithCounts from "../components/home/ServicesWithCounts.astro";
import FeaturedWorks from "../components/home/FeaturedWorks.astro";
import ProcessNumbered from "../components/home/ProcessNumbered.astro";
import Testimonials from "../components/home/Testimonials.astro";
import HomeInsight from "../components/home/HomeInsight.astro";
import FAQ from "../components/home/FAQ.astro";
import ContactCTA from "../components/home/ContactCTA.astro";
import { fetchMeta, fetchFeatured, fetchHero, fetchFaqs, fetchTestimonials, fetchServices, fetchCategories } from "../lib/crm-client";
import { pageSchemas, resolveSiteUrl, ensureMinDescription } from "../lib/seo";
import { LIMITS } from "../lib/config";

const [meta, featured, heroWorks, faqs, testimonials, services, categories] = await Promise.all([
    fetchMeta(),
    fetchFeatured(LIMITS.HOME_FEATURED),
    fetchHero(),
    fetchFaqs(),
    fetchTestimonials(),
    fetchServices(),
    fetchCategories(),
]);

// Show real published works only — no FAKE_FEATURED padding. The grid
// layout collapses gracefully when fewer than 9 works are returned.
const featured9 = featured.slice(0, 9);

const siteUrl = resolveSiteUrl(Astro.site);
const description = ensureMinDescription(
    meta.seo_default_description,
    `${meta.company_name_zh}（${meta.company_name_en}）— 商業廣告、紀錄片、活動紀錄、動畫設計，台北中山專業影像製作公司。`,
);

// 全部從 admin「網站設定 + SEO 內容」即時來源生成，無寫死。
const schemaData = [
    pageSchemas.organization(meta, siteUrl),
    pageSchemas.localBusiness(meta, siteUrl),
    pageSchemas.website(meta, siteUrl),
    ...pageSchemas.testimonialBundle(testimonials),
];

const visibleFaqs = faqs.filter(f => f.visible);
if (visibleFaqs.length > 0) {
    schemaData.push(pageSchemas.faqPage(
        visibleFaqs.map(f => ({ question: f.question_zh, answer: f.answer_zh })),
    ));
}

// admin「🏠 首頁設定」可編的 home.* 設定（透過 /meta 暴露；空則元件用各自預設）。
// Showreel 優先用專屬 home.showreel_id，未設則沿用原 home.hero_youtube_id。
const showreelId = meta.home_showreel_id || meta.home_hero_youtube_id || "DRavYkTojAo";
const homeStats = meta.home_stats || [];
const ratingValue = meta.home_rating_value || "4.9";
const ratingCount = meta.home_rating_count || "25";

// admin 可編輯的首頁文案（copy.home.*）；未設則各元件用硬寫 fallback。
// 統一傳一個 copy 物件給各 home 元件（DRY：元件內 `copy.<block>_zh ?? "literal"`）。
const homeCopy = meta.copy?.home ?? {};
---

<BaseLayout title={meta.company_name_zh}
            description={description}
            meta={meta}
            schemaData={schemaData}>
    <!-- SEO h1：對螢幕閱讀器與爬蟲提供清楚的頁面主題；視覺上隱藏不影響設計 -->
    <h1 class="sr-only">{meta.company_name_zh} — {meta.tagline || meta.subtitle || "專業影像製作"}</h1>
    <HomeSlideshow works={heroWorks} />
    <WhoWeAre showreel_id={showreelId} stats={homeStats} copy={homeCopy} />
    <ServicesWithCounts services={services} categories={categories} copy={homeCopy} meta={meta} />
    <FeaturedWorks works={featured9} copy={homeCopy} />
    <ProcessNumbered />
    <Testimonials testimonials={testimonials} ratingValue={ratingValue} ratingCount={ratingCount} copy={homeCopy} />
    <HomeInsight copy={homeCopy} />
    <FAQ faqs={visibleFaqs} copy={homeCopy} />
    <ContactCTA meta={meta} copy={homeCopy} />
</BaseLayout>

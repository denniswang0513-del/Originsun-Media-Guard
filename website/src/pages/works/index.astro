---
/**
 * works/index.astro — 作品集列表（/works，可帶 ?category=slug，白底）
 * Client-side filter：全部 render，JS 依 URL query 隱藏
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryFilter from "../../components/works/CategoryFilter.astro";
import WorkCard from "../../components/works/WorkCard.astro";
import Tr from "../../components/ui/Tr.astro";
import { fetchMeta, fetchCategories, fetchAllWorksCached } from "../../lib/crm-client";

const [meta, allWorks, categories] = await Promise.all([
    fetchMeta(),
    fetchAllWorksCached(),
    fetchCategories(),
]);

const activeCategory = Astro.url.searchParams.get("category") || null;

// 依 kind 切兩排：分類（製作類型）+ 標籤（使用場景）。舊資料 kind 為空當分類處理。
const cats = categories.filter(c => (c.kind ?? "category") === "category");
const tags = categories.filter(c => c.kind === "tag");
---

<BaseLayout title="作品集 Works" meta={meta}>
    <!-- Pagefind 搜尋（靜態站全站索引），CSS 從 npm 包載 -->
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <section class="pt-32 pb-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <p class="text-xs tracking-[0.4em] text-neutral-500 uppercase mb-3">Portfolio</p>
                <h1 class="text-4xl sm:text-5xl font-light tracking-tight text-neutral-900">
                    <Tr k="works_title" />
                </h1>
            </div>

            <!-- 搜尋框：作品多時派得上用場（少時直接看 chips 即可）-->
            <div id="works-search" class="max-w-md mx-auto mb-10"></div>

            <CategoryFilter categories={cats} activeSlug={activeCategory} label="分類" />
            {tags.length > 0 && (
                <CategoryFilter categories={tags} activeSlug={activeCategory} showAll={false} label="標籤" />
            )}

            <div id="works-grid"
                 data-active-category={activeCategory || ""}
                 class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
                {allWorks.map(work => (
                    <div class="work-item" data-categories={work.categories.join(",")}>
                        <WorkCard work={work} />
                    </div>
                ))}
            </div>

            <div id="works-empty" class="py-20 text-center text-neutral-500 hidden">
                <Tr k="works_no_items" />
            </div>
        </div>
    </section>
</BaseLayout>

<script>
    const params = new URLSearchParams(window.location.search);
    const cat = params.get("category") || "";
    if (cat) {
        let visible = 0;
        document.querySelectorAll<HTMLElement>(".work-item").forEach(el => {
            const cats = (el.dataset.categories || "").split(",");
            const show = cats.includes(cat);
            el.style.display = show ? "" : "none";
            if (show) visible++;
        });
        const empty = document.getElementById("works-empty");
        const grid = document.getElementById("works-grid");
        if (visible === 0 && empty && grid) {
            grid.classList.add("hidden");
            empty.classList.remove("hidden");
        }
    }
</script>

<!-- Pagefind UI 動態載入 — pagefind-ui.js 會在 build 時 npm 包進 dist/pagefind/ -->
<script type="module">
    // @ts-expect-error - Pagefind 由 build 時 cli 自動 emit 到 /pagefind/
    const { PagefindUI } = await import("/pagefind/pagefind-ui.js");
    new PagefindUI({
        element: "#works-search",
        showImages: false,           // 作品 thumbnail 已經在卡片，不重複顯示
        showSubResults: false,
        resetStyles: false,
        translations: {
            placeholder: "搜尋作品名稱、客戶、Credits…",
            zero_results: "找不到符合 [SEARCH_TERM] 的結果",
        },
    });
</script>

---
/**
 * works/index.astro — 作品集列表（/works，可帶 ?category=slug，白底）
 * Client-side filter：全部 render，JS 依 URL query 隱藏
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryFilter from "../../components/works/CategoryFilter.astro";
import TagCloud from "../../components/works/TagCloud.astro";
import WorkCard from "../../components/works/WorkCard.astro";
import Tr from "../../components/ui/Tr.astro";
import { fetchMeta, fetchCategories, fetchAllWorksCached } from "../../lib/crm-client";
import { buildBasicPageSeo, breadcrumb2 } from "../../lib/seo";

const [meta, allWorks, categories] = await Promise.all([
    fetchMeta(),
    fetchAllWorksCached(),
    fetchCategories(),
]);

const activeCategory = Astro.url.searchParams.get("category") || null;
const activeTag = Astro.url.searchParams.get("tag") || null;

// 依 kind 切兩排：分類（製作類型）+ 標籤（使用場景）。舊資料 kind 為空當分類處理。
const cats = categories.filter(c => (c.kind ?? "category") === "category");
const tags = categories.filter(c => c.kind === "tag");

// 切軸時保留另一軸：點分類不丟 tag、點 tag 不丟分類。傳給 chip 元件當 extraQuery。
const catQueryStr = activeCategory ? `category=${activeCategory}` : "";
const tagQueryStr = activeTag ? `tag=${activeTag}` : "";
const tagAllHref = catQueryStr ? `/works?${catQueryStr}` : "/works";

const activeName = activeCategory
    ? categories.find(c => c.slug === activeCategory)?.name_zh || activeCategory
    : (activeTag ? categories.find(c => c.slug === activeTag)?.name_zh || activeTag : null);
const pdfUrl = (meta.portfolio_pdf_url || "").trim();
const seo = buildBasicPageSeo(Astro, {
    title: "作品集 Works",
    description: activeName
        ? `${meta.company_name_zh} ${activeName} 類別作品集 — 從商業廣告、紀錄片到活動紀錄，瀏覽 ${meta.company_name_zh} 影像製作成果。`
        : `${meta.company_name_zh}歷年作品集 — 商業廣告、紀錄片、活動紀錄、動畫設計，共 ${allWorks.length} 件作品按類別瀏覽，台北中山影像製作公司。`,
    breadcrumbs: breadcrumb2("作品集", "/works"),
});
---

<BaseLayout {...seo} meta={meta}>
    <!-- Pagefind 搜尋（靜態站全站索引），CSS 從 npm 包載 -->
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <section class="pt-32 pb-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <p class="text-xs tracking-[0.4em] text-neutral-500 uppercase mb-3">Portfolio</p>
                <h1 class="text-4xl sm:text-5xl font-light tracking-tight text-neutral-900">
                    <Tr k="works_title" />
                </h1>
                {pdfUrl && (
                    <a href={pdfUrl} target="_blank" rel="noopener"
                       class="inline-flex items-center gap-2 mt-6 text-xs tracking-[0.25em] uppercase border border-neutral-900 text-neutral-900 px-5 py-2 hover:bg-neutral-900 hover:text-white transition-colors">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                            <line x1="12" y1="18" x2="12" y2="12" />
                            <polyline points="9 15 12 18 15 15" />
                        </svg>
                        <Tr zh="作品集 PDF" en="Portfolio PDF" />
                    </a>
                )}
            </div>

            <!-- 搜尋框：作品多時派得上用場（少時直接看 chips 即可）-->
            <div id="works-search" class="max-w-md mx-auto mb-10"></div>

            <CategoryFilter categories={cats} activeSlug={activeCategory}
                            label="分類" queryKey="category"
                            extraQuery={tagQueryStr} />
            {tags.length > 0 && (
                <div class="mt-6 text-center">
                    <h2 class="text-xs tracking-[0.4em] uppercase text-neutral-500 mb-4">Tags</h2>
                    <div class="flex justify-center">
                        <TagCloud tags={tags} activeSlug={activeTag}
                                  linkBase="/works?tag="
                                  showAll={true}
                                  allHref={tagAllHref}
                                  extraQuery={catQueryStr} />
                    </div>
                </div>
            )}

            <div id="works-grid"
                 data-active-category={activeCategory || ""}
                 data-active-tag={activeTag || ""}
                 class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10">
                {allWorks.map(work => (
                    <div class="work-item"
                         data-categories={(work.categories || []).join(",")}
                         data-tags={(work.tags || []).join(",")}>
                        <WorkCard work={work} />
                    </div>
                ))}
            </div>

            <div id="works-more-wrap" class="mt-12 text-center hidden">
                <button id="works-more-btn" type="button"
                        class="inline-flex items-center gap-2 text-xs tracking-[0.25em] uppercase border border-neutral-900 text-neutral-900 px-8 py-3 hover:bg-neutral-900 hover:text-white transition-colors">
                    <Tr zh="載入更多" en="Load more" />
                    <span id="works-more-count" class="text-neutral-400 tracking-normal"></span>
                </button>
            </div>

            <div id="works-empty" class="py-20 text-center text-neutral-500 hidden">
                <Tr k="works_no_items" />
            </div>
        </div>
    </section>
</BaseLayout>

<script>
    const params = new URLSearchParams(window.location.search);
    const cat = params.get("category") || "";
    const tag = params.get("tag") || "";

    // ── Step 1: 重寫所有 chip href，保留 cross-axis ──
    // Astro SSG build 時 Astro.url.searchParams 永遠空，靜態頁裡的 chip 預設都丟掉另一軸；
    // 在 client-side 根據實際 URL 重新組 href，讓 user 點 chip 不會清掉另一軸。
    function buildHref(axis: string, slug: string): string {
        const next = new URLSearchParams();
        if (axis === "category") {
            if (slug) next.set("category", slug);
            if (tag) next.set("tag", tag);
        } else if (axis === "tag") {
            if (slug) next.set("tag", slug);
            if (cat) next.set("category", cat);
        }
        const qs = next.toString();
        return qs ? `/works?${qs}` : "/works";
    }

    // ── Step 2: 切 active class（Astro SSG 看不到實際 query，預設都把「全部」反白；
    //              client 根據真實 URL 修正 active 標）──
    // 統一色系：兩軸 active 都用黑底白字、inactive 中性灰；axis 差異只在邊框（cat 有 / tag 無）
    const CAT_ACTIVE = ["border-neutral-900", "bg-neutral-900", "text-white"];
    const CAT_INACTIVE = ["border-neutral-300", "text-neutral-500", "hover:border-neutral-900", "hover:text-neutral-900"];
    const TAG_ACTIVE = ["bg-neutral-900", "text-white", "hover:bg-neutral-800"];
    const TAG_INACTIVE = ["bg-neutral-100", "text-neutral-500", "hover:bg-neutral-200", "hover:text-neutral-900"];

    function applyChipState(): void {
        document.querySelectorAll<HTMLAnchorElement>("[data-chip-axis]").forEach(a => {
            const axis = a.dataset.chipAxis || "";
            const slug = a.dataset.chipSlug || "";
            a.href = buildHref(axis, slug);
            const isActive = axis === "category" ? slug === cat : slug === tag;
            const [activeCls, inactiveCls] = axis === "category"
                ? [CAT_ACTIVE, CAT_INACTIVE]
                : [TAG_ACTIVE, TAG_INACTIVE];
            a.classList.remove(...activeCls, ...inactiveCls);
            a.classList.add(...(isActive ? activeCls : inactiveCls));
        });
    }
    applyChipState();

    // ── Step 3: 過濾作品卡片（AND of cat + tag）+ 分批顯示（載入更多）──
    // 全部作品都在 HTML（SEO 友善），初次只顯示前 PAGE_SIZE 件、其餘 display:none
    // （lazy 圖不會載入 → 手機首屏更快），按「載入更多」逐批揭開。
    // 切分類/標籤是整頁導航（chip 是 <a>）→ 每次載入自然重置到第一批。
    const PAGE_SIZE = 24;
    const matched: HTMLElement[] = [];
    document.querySelectorAll<HTMLElement>(".work-item").forEach(el => {
        const cats = (el.dataset.categories || "").split(",");
        const tagsArr = (el.dataset.tags || "").split(",");
        const show = (!cat || cats.includes(cat)) && (!tag || tagsArr.includes(tag));
        if (show) matched.push(el);
        else el.style.display = "none";
    });

    const moreWrap = document.getElementById("works-more-wrap");
    const moreBtn = document.getElementById("works-more-btn");
    const moreCount = document.getElementById("works-more-count");
    let shown = 0;
    function renderLimit(): void {
        matched.forEach((el, i) => { el.style.display = i < shown ? "" : "none"; });
        if (!moreWrap) return;
        if (shown < matched.length) {
            moreWrap.classList.remove("hidden");
            if (moreCount) moreCount.textContent = `(${shown}/${matched.length})`;
        } else {
            moreWrap.classList.add("hidden");
        }
    }
    shown = Math.min(PAGE_SIZE, matched.length);
    renderLimit();
    moreBtn?.addEventListener("click", () => {
        shown = Math.min(shown + PAGE_SIZE, matched.length);
        renderLimit();
    });

    const visible = matched.length;
    const empty = document.getElementById("works-empty");
    const grid = document.getElementById("works-grid");
    if (visible === 0 && empty && grid) {
        grid.classList.add("hidden");
        empty.classList.remove("hidden");
    } else if (grid && empty) {
        grid.classList.remove("hidden");
        empty.classList.add("hidden");
    }
</script>

<!-- Pagefind UI 動態載入 — pagefind-ui.js 會在 build 時 npm 包進 dist/pagefind/ -->
<script type="module">
    // @ts-expect-error - Pagefind 由 build 時 cli 自動 emit 到 /pagefind/
    const { PagefindUI } = await import("/pagefind/pagefind-ui.js");
    new PagefindUI({
        element: "#works-search",
        showImages: false,           // 作品 thumbnail 已經在卡片，不重複顯示
        showSubResults: false,
        resetStyles: false,
        translations: {
            placeholder: "搜尋作品名稱、客戶、Credits…",
            zero_results: "找不到符合 [SEARCH_TERM] 的結果",
        },
    });
</script>

---
/**
 * BaseLayout.astro — 全站外殼（<html> + <head> + <body> + Header/Footer）
 *
 * SEO 鐵閘（Stage 0 起）：
 * - description 必填（不可省、不可 fallback 全站預設）
 * - schemaData 必填（至少 1 個 schema，最少給 pageSchemas.webPage）
 * - 兩者沒給 → TypeScript build 階段就紅線
 * - 即使編譯過，build 末段 seo-audit integration 還會掃 dist/ HTML 把關
 *
 * 寫新頁面的最小寫法：
 *   <BaseLayout
 *       title="頁面標題"
 *       description="60-160 字的 SEO 描述..."
 *       meta={meta}
 *       schemaData={[pageSchemas.webPage({title, description, url: canonical})]}
 *   >
 */
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import type { IWebsiteMeta } from "../types/meta";
import type { SchemaObject } from "../types/seo";
import { canonicalUrl } from "../lib/seo";
import "../styles/global.css";

interface Props {
    title: string;
    description: string;          // 必填 — SEO 核心欄位，每頁都要寫
    schemaData: SchemaObject[];   // 必填 — 至少 1 個 schema
    meta: IWebsiteMeta;
    noindex?: boolean;            // 不傳 → 走 meta.indexable；傳 true/false → 強制覆寫
    ogImage?: string;
    canonical?: string;           // 跨站發布時指向原作（少用）— 不傳預設走 Astro.url.pathname
}

// 預設：admin 在 settings 把 seo.indexable 打開後對外網站才允許索引；
// 個別頁面（如 thank-you / utility 頁）可以傳 noindex={true} 強制隱藏。
const { title, description, schemaData, meta, ogImage } = Astro.props;
const noindex = Astro.props.noindex ?? !meta.indexable;

const fullTitle = title === meta.company_name_zh ? title : `${title} | ${meta.company_name_zh}`;

// Google SERP 截在 ~155 字，自己截避免被砍在句中
function _truncate(s: string, max = 155): string {
    const oneLine = s.replace(/\s+/g, " ").trim();
    return oneLine.length <= max ? oneLine : oneLine.slice(0, max - 1) + "…";
}
const desc = _truncate(description);
// canonical 優先序：caller 傳入（per-page override）> Astro.url.pathname 自動算
const canonical = Astro.props.canonical || canonicalUrl(Astro.site, Astro.url.pathname);
const finalOgImage = ogImage || meta.seo_og_image || undefined;
---

<!doctype html>
<html lang="zh-Hant" data-lang="zh">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        {/* 分頁圖示：專屬 favicon > 品牌 Logo > 預設紅日。上傳 Logo 也會更新分頁圖示。 */}
        {(meta?.brand_favicon_url || meta?.brand_logo_url)
            ? <link rel="icon" href={meta.brand_favicon_url || meta.brand_logo_url} />
            : <link rel="icon" type="image/svg+xml" href="/favicon.svg" />}

        <title>{fullTitle}</title>
        <meta name="description" content={desc} />
        <link rel="canonical" href={canonical} />

        {noindex && <meta name="robots" content="noindex, nofollow" />}

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={desc} />
        <meta property="og:url" content={canonical} />
        <meta property="og:site_name" content={meta.company_name_zh} />
        {finalOgImage && <meta property="og:image" content={finalOgImage} />}

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={fullTitle} />
        <meta name="twitter:description" content={desc} />
        {finalOgImage && <meta name="twitter:image" content={finalOgImage} />}

        <!-- AI / RSS feeds — discovery for ChatGPT/Perplexity/Feedly etc -->
        <link rel="alternate" type="application/feed+json" href="/feed.json" title={`${meta.company_name_zh} 影像專欄`} />
        <link rel="alternate" type="application/rss+xml" href="/rss.xml" title={`${meta.company_name_zh} 影像專欄`} />

        {schemaData.map((d) => (
            <script is:inline type="application/ld+json" set:html={JSON.stringify(d)} />
        ))}

        {/* Google Analytics 4（gtag）— admin 在「網站設定 › 分析追蹤」填 ID 後注入。
            只在 G- 開頭的合法 GA4 ID 時載入，避免空值 / 誤填打壞頁面。 */}
        {meta.analytics_ga_id?.startsWith("G-") && (
            <>
                <script
                    is:inline
                    async
                    src={`https://www.googletagmanager.com/gtag/js?id=${meta.analytics_ga_id}`}
                ></script>
                <script is:inline set:html={`
                    window.dataLayer = window.dataLayer || [];
                    function gtag(){dataLayer.push(arguments);}
                    gtag('js', new Date());
                    gtag('config', '${meta.analytics_ga_id}');
                `}></script>
            </>
        )}

        <!-- lite-youtube-embed（輕量 YouTube 佔位元件，只在點擊時載入 iframe）。
             CSS 用 media=print + onload 切回 all → 非阻斷算繪（首屏不等它下載）；
             JS 已 defer。lite-youtube 只在使用者點播放後才需要，延後零副作用。 -->
        <script is:inline src="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.3/src/lite-yt-embed.js" defer></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.3/src/lite-yt-embed.css"
              media="print" onload="this.media='all'" />
        <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.3/src/lite-yt-embed.css" /></noscript>

        <!-- 早期套用 localStorage 語系避免閃爍 -->
        <script is:inline>
            (function () {
                try {
                    const saved = localStorage.getItem("lang");
                    if (saved === "zh" || saved === "en") {
                        document.documentElement.setAttribute("data-lang", saved);
                        document.documentElement.setAttribute("lang", saved === "zh" ? "zh-Hant" : "en");
                    }
                } catch (_) {}
            })();
        </script>
    </head>
    <body class="bg-white text-neutral-800 antialiased">
        <Header meta={meta} />
        <main class="min-h-screen">
            <slot />
        </main>
        <Footer meta={meta} />
    </body>
</html>

<style is:global>
    /* 雙語切換：data-lang=zh 時隱藏 en，反之亦然 */
    html[data-lang="zh"] [data-lang-en] { display: none !important; }
    html[data-lang="en"] [data-lang-zh] { display: none !important; }

    html { scroll-behavior: smooth; }

    /* 白底配色 —— 對齊 originsun-studio.com 舊站風格
       accent 為 Logo 紅，少量使用在 hover / 裝飾線 */
    :root {
        --accent: #c9372c;
        --accent-hover: #a02921;
        --text-strong: #111;
        --text: #333;
        --text-muted: #888;
        --line: #e5e5e5;
    }

    body { color: var(--text); }
    /* h1-h4 預設色移到 global.css 的 @layer base，讓 text-white 等 utility 能蓋過 */
</style>
